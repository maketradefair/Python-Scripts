     /**\n         * Opens a dashboard template creation window allowing the user to create a new object.\n         * @param {Object} optional - listeners applied to the current action\n         * @param {Object} optional - scope applied to the action\n         * @param {Object} optional - additional options\n         */\n        createDashboardTemplate: function(listeners, options) {\n            new portal.customdashboard.dialog.NewTemplateDialog({\n                listeners: listeners,\n                type: 'dashboard',\n                templateService: this.dashboardTemplateService,\n                config: options.config\n            }).show();\n        },\n\n        export: function(type, exportObject, listeners) {\n            new portal.customdashboard.dialog.ExportDialog({\n                type: type,\n                exportObject: exportObject,\n                listeners: listeners\n            }).show();\n        },\n\n        import: function(type, dashboardId, listeners) {\n            new portal.customdashboard.dialog.ImportDialog({\n                type: type,\n                dashboardId: dashboardId,\n                listeners: listeners\n            }).show();\n        },\n        /**\n         * Opens a widget template creation window allowing the user to create a new object.\n         * @param {Object} optional - listeners applied to the current action\n         * @param {Object} optional - scope applied to the action\n         * @param {Object} optional - additional options\n         */\n        createWidgetTemplate: function(listeners, options) {\n            new portal.customdashboard.dialog.NewTemplateDialog({\n                listeners: listeners,\n                type: 'widget',\n                templateService: this.widgetTemplateService,\n                config: options.config\n            }).show();\n        },\n\n        /**\n         * Opens a window that allows the user to edit a dashboard.\n         * @param {id} - id of object to open\n         * @param {Object} optional - listeners applied to the current action\n         * @param {Object} optional - scope applied to the action\n         * @param {Object} optional - additional options\n         */\n        edit: function(dashboard, listeners, options) {\n            this.dashboardService.getDashboard(dashboard.id, {\n                scope: this,\n                success: function(data) {\n                    new portal.customdashboard.dialog.EditDashboardDialog({\n                        dashboardService: this.dashboardService,\n                        dashboard: data,\n                        listeners: listeners\n                    }).show();\n                },\n                failure: function(err, msg) {\n                    new portal.core.dialog.ErrorDialog($L('99f5c1d0-1307-432a-8cb2-1465b66fd8c4', 'Dashboard Update'), [\n                        $L('33d29c1d-f914-456b-990c-f623d9fac48d', 'Could not open the dashboard properties.')\n                    ].join('<br/>')).show();\n                }\n            });\n        },\n\n        /**\n         * Requires deletion confirmation and then calls the appropriate delete service.\n         * @param {Mixed} - id or array of ids of host(s) to delete\n         * @param {Object} optional - listeners applied to the current action\n         * @param {Object} optional - scope applied to the action\n         * @param {Object} optional - additional options\n         */\n        remove: function(mixedIds, listeners, scope, options) {\n            var opt = Ext.apply(options || {}, {\n                dialogCfg: {\n                    svc: this.dashboardService,\n                    hasDependencies: false,\n                    svcDeleteFn: this.dashboardService.deleteDashboards,\n                    dialogTitle: $L('b2f4c802-80c5-431c-bd76-de9e7556ccba', 'Dashboard'),\n                    dialogEntityName: 'dashboard',\n                    confirmMsg: $L('d3399596-607a-46cb-8851-355809fa33a8', 'The dashboard has been successfully deleted.')\n                }\n            });\n            this.common.remove(mixedIds, listeners, scope, opt);\n        },\n\n        unregisterTrendQueries: function (tiles) {\n            var uuids = [];\n            Ext.each(tiles, function (tile) {\n                if (tile.state.trend1UUID) {\n                    uuids.push(tile.state.trend1UUID);\n                }\n                if (tile.state.trend2UUID) {\n                    uuids.push(tile.state.trend2UUID);\n                }\n            });\n            if (uuids.length) {\n                Service('asset.TrendingDashboardService').deregisterQueriesForTrending(uuids);\n            }\n        }\n\n    };\n\n})();\n;\n/**\n * Customizable dashboard panel.\n *\n * @class portal.customdashboard.DashboardPanel\n * @extends Ext.Container\n *\n */\n\n//import portal.customdashboard.form.DashboardSelector\n//import portal.customdashboard.dialog.NewWidgetWizard\n//import portal.customdashboard.portlet.PortletChart\n//import portal.customdashboard.dialog.EditWidgetDialog\n//import portal.customdashboard.DashboardActions\n//import portal.core.dialog.ErrorDialog\n//import /portal/customdashboard/assets/css/dashboard.css\n\n(function() {\n    var NS = Q.Util.namespace(\"portal.customdashboard\");\n    var $cls = NS.DashboardPanel = function(cfg) {\n\n        this.sectionName = cfg.sectionName || 'DASHBOARD';\n        this.autoLoadDashboard = cfg.autoLoadDashboard !== false;\n        this.trendingFeatureEnabled = Passport.getCustomerModuleSetting(\"ASSET_MANAGEMENT\", \"enableDashboardTrending\");\n        this.overlay = Ext.apply({\n            dismissText: $L('1a844115-ba52-4803-ad7d-219b627c730e', 'Continue'),\n            title: $L('4d177a8b-0099-4026-8af2-ed0d52d4c653', 'Welcome to your Dashboard'),\n            subtitle: $L('c627edc7-c41c-46f0-86b3-78d84c48f811', 'Here are a few quick tips to help get you up and running.'),\n            items: [\n                {\n                    top: 50,\n                    left: function() { return Math.max(0, PageFrame.getOffset()) + 300; },\n                    title: $L('eaccc959-b550-40ad-8e22-ace345e85d56', 'Navigate with ease'),\n                    html: $L('3718214a-3233-4150-92ba-1953d5e8501e', 'Navigate between your apps by using the module picker.'),\n                    anchorCls: 'anchor-left',\n                    anchorLength: 90\n                },\n                {\n                    alignTo: function() { return this.dashboardSelector.el.child('span'); }.createDelegate(this),\n                    position: 'l-r',\n                    offsets: [ 15, 14 ],\n                    title: $L('b27a8d4e-8a52-4de5-929a-fa8c95942a1f', 'View your custom dashboards'),\n                    html: $L('0677d75f-00ed-4d45-aabf-37d539b840c2', 'Choose your view. Everytime you save a new dashboard, it will be stored here.'),\n                    anchorCls: 'anchor-left',\n                    anchorLength: 75\n                },\n                {\n                    top: 289,\n                    left: function() { return Math.max(0, PageFrame.getOffset()) + 109; },\n                    title: $L('65a537a4-99bf-42d4-be00-d7f11d9cad93', 'Customize dashboards'),\n                    html: $L('2ff0bbff-01fa-437f-b059-ab70b19a37d7', 'Configure the current dashboard or create a new one.'),\n                    anchorCls: 'anchor-left-up',\n                    anchorLength: 80\n                }\n            ]\n        }, cfg.overlayCfg);\n        this.landingPageButtons = cfg.landingPageButtons || [];\n        this.actions = portal.customdashboard.DashboardActions;\n        this.actions.dashboardService = cfg.dashboardService;\n        this.dashboardTemplateCategories = cfg.dashboardTemplateCategories || [];\n        this.widgetTemplateCategories = cfg.widgetTemplateCategories || [];\n        this.globalFilters = cfg.globalFilters || []; // [\"TAGS\", \"TIME\"]\n        this.dashboardService = cfg.dashboardService; // where all the widgets call home to get data\n        this.searchTokens = cfg.searchTokens || {};\n        this.pivotTokens = cfg.pivotTokens || [];\n        this.listColumns = cfg.lstColumns || [];\n        this.widgetCfg = cfg.widgetCfg;\n        this.tableColumnHeaderRenderer = cfg.tableColumnHeaderRenderer;\n        this.listColumnRenderer = cfg.listColumnRenderer;\n        this.searchHelpUrl = cfg.searchHelpUrl;\n        this.dashboardPermissions = cfg.dashboardPermissions;\n        this.text = Ext.apply({\n            leftTitle: $L('77b9ab0b-ab1a-4e2b-97f7-3faaf010313d', 'Asset Catalog'),\n            leftText: $L('c86f8a96-04a4-4237-8a0c-ee4a6ad97c42', 'You have no recent activity yet.'),\n            rightTitle: $L('35a89ca5-7633-4d15-bf1b-94ea6e1643e1', 'Asset Discovery'),\n            rightText: $L('c86f8a96-04a4-4237-8a0c-ee4a6ad97c42', 'You have no recent activity yet.'),\n            header: $L('e05ecea6-5004-4c20-b7d5-3bc710ff9493', 'Welcome to your Dashboards!'),\n            contents: $L('3d8cb299-d47e-4898-81ae-aafd94f3fe0c', \"To get started, please pick a dashboard or create a new one.\")\n        }, cfg.emptyContents, {});\n        this.allow = Ext.apply({\n            update: true,\n            create: true,\n            destroy: true\n        }, cfg.permissions, {});\n\n        /**\n         * @config {Object} filterCfg\n         *\n         */\n        this.filterCfg = {};\n        Ext.iterate(cfg.filterCfg, function(name, filterCfg) {\n            if (this.filterCfg[name] && Ext.isObject(filterCfg)) {\n                Qx.ComponentUtils.deepApply(this.filterCfg[name], filterCfg);\n            } else {\n                this.filterCfg[name] = filterCfg;\n            }\n        }, this);\n        delete cfg.filterCfg;\n\n        // properties of the tile and its state that will be saved for new templates\n        this.tileTemplateProps = [\"flex\", \"title\", \"state\", \"width\"];\n        // ***NOTE: Any changes to the tile state configuration options should also be reflected\n        //          in com.qualys.portal.application.module.dashboard.DashboardTileConfig!\n        this.tileStateTemplateProps = [\"actions\", \"chartType\", \"compare\", \"compareType\", \"query\", \"query2\", \"query2Title\", \"enableTrending\", \"trend1UUID\", \"trend2UUID\", \"title\", \"categories\", \"groupBy\", \"groupByFilters\", \"groupByFilterType\", \"limit\", \"showEmpty\", \"legend\", \"labels\", \"vertical\", \"donut\", \"resultType\", \"sort\", \"sortAsc\", \"havingQuery\"];\n        this.tileEncodeProps = [\"title\"];\n\n        $cls.superclass.constructor.call(this, Ext.apply({\n            layout: 'vbox',\n            margins:'0 0 0 0',\n            bodyBorder: false,\n            frame: true,\n            header: false,\n            unstyled: true,\n            cls: 'dashboard-v2',\n            padding: '0 0 0 0',\n            width: Ext.isDefined(PageFrame.getWidth) ? PageFrame.getWidth() : 1280,\n            layoutConfig: {\n                align : 'stretch'\n            },\n            items:[\n                this.titleCt = new Ext.Container({\n                    layout: {\n                        type: 'hbox',\n                        align: 'stretch'\n                    },\n                    height: !Ext.isDefined(this.dashboard)  ? 60 : 94,\n                    cls: 'dashboard-v2-selector-container',\n                    items: [\n                        new Ext.Container({\n                            layout: {\n                                type: 'vbox',\n                                align: 'stretch'\n                            },\n                            flex: 1,\n                            items: [\n                                this.dashboardSelector = new portal.customdashboard.form.DashboardSelector({\n                                    height: 60,\n                                    svc: this.dashboardService,\n                                    autoLoadDashboard: this.autoLoadDashboard,\n                                    listeners: {\n                                        'select': this.loadDashboard,\n                                        scope: this\n                                    }\n                                }),\n                                this.toolbar = new Ext.Toolbar({\n                                    hidden: !Ext.isDefined(this.dashboard),\n                                    cls: 'dashboard-v2-toolbar',\n                                    height: 24,\n                                    margins: '0 0 10 10',\n                                    items: [{\n                                        cls: 'qx-btn-filter',\n                                        text: $L('5ee0da8f-6319-4a09-8e82-276844ea54e0', 'Actions'),\n                                        menu: {\n                                            cls: 'qx-menu',\n                                            shadow: false,\n                                            showSeparator: false,\n                                            hideBorders: true,\n                                            items: [{\n                                                text: $L('5901f6a7-2cf0-4560-ad09-72a6018c35b4', 'Configure Dashboard'),\n                                                handler: this.editDashboard,\n                                                hidden: !this.allow.update,\n                                                scope: this\n                                            }, {\n                                                text: $L('afc47b8e-98e3-4980-8e88-46e24abfc36f', 'Set as Default Dashboard'),\n                                                handler: this.makeDefault,\n                                                scope: this\n                                            }].concat(this.allow.create ? ['-', {\n                                                text: $L('155bf2af-c14e-41e6-b55d-cac02dfd32b5', 'Create Template from this Dashboard'),\n                                                handler: this.createNewDashboardTemplate,\n                                                scope: this\n                                            }] : []).concat(this.allow.create ? ['-', {\n                                                text: $L('ab593bfa-cfc1-438b-81ac-82d10964d8a2', 'Create New Dashboard'),\n                                                handler: this.createNewDashboard,\n                                                scope: this\n                                            }] : []).concat(this.allow.destroy ? ['-', {\n                                                text: $L('a509efd5-73bb-46bf-926f-2a3f2427ad55', 'Delete this Dashboard'),\n                                                handler: this.removeDashboard,\n                                                scope: this\n                                            }] : []).concat(['-',{\n                                                text: $L('000caadd-ee13-4e23-857d-7821612b3ede', 'Print Dashboard'),\n                                                handler: this.printDashboard,\n                                                hidden: !this.allow.update,\n                                                scope: this\n                                            }]).concat(this.allow.create || this.allow.update ? ['-'] : []).concat(this.allow.create ? [{\n                                                text: $L('7d98b86d-db7f-4e52-97de-9aeb8be516cd', 'Export this Dashboard'),\n                                                handler: this.exportDashboard,\n                                                scope: this\n                                              }, {\n                                                text: $L('bb6b8392-9eb1-4621-9639-99536b291e10', 'Import New Dashboard'),\n                                                handler: this.importDashboard,\n                                                scope: this\n                                              }] : []).concat(this.allow.update ? [{\n                                                text: $L('29b7c274-9c11-4956-a64c-9f8093408619', 'Import New Widget'),\n                                                handler: this.importWidget,\n                                                scope: this\n                                              }] : []).concat(['-',{\n                                                text: $L('Migrate Dashboard to UD'),\n                                                handler: this.migrateToUD,\n                                                hidden: !Passport.user.superuser,\n                                                scope: this\n                                            }])\n                                        },\n                                        scope: this\n                                    }, { xtype: 'tbspacer', width: 10 }, {\n                                        cls: 'qx-btn-filter',\n                                        text: $L('4eed5168-2cc4-4e77-a56d-4729e5d2beda', 'Add Widget'),\n                                        handler: this.addNewWidget,\n                                        hidden: !this.allow.update,\n                                        scope: this\n                                    }]\n                                })\n                            ]\n                        }),\n                        new Ext.Container({\n                            layout: {\n                                type: 'hbox',\n                                align: 'stretch'\n                            },\n                            flex:1,\n                            items : [\n                                this.filterContainer = new Ext.Container({\n                                    hidden: !Ext.isDefined(this.dashboard),\n                                    layout: 'hbox',\n                                    flex: 1,\n                                    cls: 'dashboard-v2-filter-container',\n                                    layoutConfig: { align: 'top' },\n                                    items: [{ xtype: 'spacer', flex: 1 }].concat(this.createFilterItems()),\n                                    getFilterValues: function() {\n                                        var filters = {};\n                                        this.items.each(function(filter) {\n                                            if (!filter.hidden && filter.getValue) {\n                                                filters[filter.name] = filter.getValue();\n                                            }\n                                        });\n                                        return filters;\n                                    }\n                                }),\n                                this.refreshContainer = new Ext.BoxComponent({\n                                    hidden: !Ext.isDefined(this.dashboard),\n                                    html: '<div class=\"dashboard-v2-refresh-container\" ext:qtip=\"' + $L('8eec567b-9807-49e3-b98d-f6f458dc9b9d', 'Refresh All') + '\"></div>',\n                                    width: 40,\n                                    listeners: {\n                                        'afterrender': function(cmp){\n                                            cmp.getEl().on('click', this.refreshDashboard.createDelegate(this, [true, true]));\n                                        },\n                                        scope: this\n                                    }\n                                })\n                            ],\n                            scope: this\n                        })\n                    ]\n                }),\n                this.mosaic = new Qx.panel.Mosaic({\n                    hidden: !Ext.isDefined(this.dashboard),\n                    flex: 1,\n                    defaultTileHeight: 200,\n                    minTileWidth: 100,\n                    minTileHeight: 100,\n                    parent: this,\n                    readOnly: !this.allow.update,\n                    i18n: {\n                        addAWidget: '<div class =\"mosaic-text\">' + $L('c5e3861f-bc6e-4f8e-bf0f-6e3f97ba0005', \"Add a Widget\") + '</div>'\n                    },\n                    tileDefaultConfig: {\n                        actions: this.allow.update ? [{\n                            text: $L('a2fcaf15-8484-4fd8-81c3-1c1f8208bc3f', 'Configure Widget'),\n                            handler: function() {\n                                this.tile.mosaic.unzoomActiveTile();\n                                var dashboard = this.tile.mosaic.parent;\n                                dashboard.editWidget(this.tile);\n                            }\n                        }, {\n                            text: $L('b7db7431-165d-4087-94ee-150b4d6d019d', 'Refresh Widget'),\n                            handler: function() {\n                                var dashboard = this.tile.mosaic.parent;\n                                dashboard.refreshTile(this.tile, true);\n                            }\n                        },\"-\", {\n                            text: $L('31787a64-a163-4ece-9e67-41ba76437d4d', 'Create Template from this Widget'),\n                            handler: function(menu) {\n                                this.mosaic.unzoomActiveTile();\n                                this.createNewWidgetTemplate(menu);\n                            },\n                            scope: this\n                        },\"-\", {\n                            text: $L('de9847b5-3cee-474c-877f-31ae8b654f11', 'Export this Widget'),\n                            handler: function(menu) {\n                                this.mosaic.unzoomActiveTile(menu);\n                                this.exportWidget(menu.tile);\n                            },\n                            scope: this\n                        }, '-', {\n                            text: $L('9e3cfeea-d77e-4711-9301-fdc8861768d6', 'Remove Widget'),\n                            handler: function (menu) {\n                                this.removeWidget = true;\n                                this.mosaic.unzoomActiveTile();\n                                this.actions.unregisterTrendQueries([menu.tile]);\n                                menu.tile.mosaic.removeTile(menu.tile);\n\n                            },\n                            scope: this\n                        }] : []\n                    },\n                    listeners: {\n                        scope: this,\n                        tileadd: this.onTileAdd,\n                        beforetilezoom: this.onBeforeTileZoom,\n                        tileunzoom: this.onTileUnzoom,\n                        change: this.onUpdateWidget,\n                        load: this.onLoad,\n                        resize: function() { this.refreshDashboard(); },\n                        afterRender: function(mosaic) {\n                          this.mon(Ext.getBody(), 'click', function(el, e) {\n                            if (!Ext.fly(el.getTarget()).findParent('.main-frame-container')) {\n                              mosaic.zoomedTile && mosaic.zoomedTile.tile.mosaic.unzoomActiveTile();\n                           }\n                         },mosaic);\n                          mosaic.el.on('scroll', function() { this.refreshDashboard(); }, this, {buffer: 200});\n                        }\n                    },\n                    onAddTileClick: this.addNewWidget,\n                    scope: this\n                }),\n                this.emptyNotice = new Ext.BoxComponent({\n                    flex: 1,\n                    cls: 'dashboard-v2-empty-box-container',\n                    hidden: Ext.isDefined(this.dashboard),\n                    html: ['<div class=\"dashboard-v2-intro-text\">',\n                                '<h2>',\n                                     this.text.header,\n                                '</h2>',\n                                '<p>',\n                                    this.text.contents,\n                                '</p><br/>',\n                                '<div class=\"dashboard-v2-btn-container\"></div>',\n                            '</div>',\n                            '<div class=\"dashboard-v2-empty-containers\">',\n                                '<div class=\"dashboard-v2-empty-container\">',\n                                    '<div class=\"dashboard-v2-empty-container-header\">', this.text.leftTitle, '</div>',\n                                    '<div class=\"dashboard-v2-empty-panel\">',\n                                        '<span class=\"dashboard-v2-empty-panel-icon dashboard-v2-empty-panel-icon-pie\"></span>',\n                                        '<span class=\"dashboard-v2-empty-panel-notice\">', this.text.leftText, '</span>',\n                                    '</div>',\n                                '</div>',\n                                '<div class=\"dashboard-v2-empty-container\">',\n                                    '<div class=\"dashboard-v2-empty-container-header\">', this.text.rightTitle, '</div>',\n                                    '<div class=\"dashboard-v2-empty-panel\">',\n                                        '<span class=\"dashboard-v2-empty-panel-icon dashboard-v2-empty-panel-icon-clock\"></span>',\n                                        '<span class=\"dashboard-v2-empty-panel-notice\">', this.text.rightText, '</span>',\n                                    '</div>',\n                                '</div>',\n                            '</div>'].join(''),\n                    listeners: {\n                        scope: this,\n                        afterrender: function(box) {\n                            var target = box.el.child('.dashboard-v2-btn-container');\n                            if (this.allow.create) {\n                                Ext.create({\n                                    xtype: 'button',\n                                    cls: 'q-btn-blue-dark',\n                                    text: $L('f058ab7f-7284-423c-8d17-dbcf6a040fe6', 'New Dashboard'),\n                                    handler: this.createNewDashboard,\n                                    scope: this,\n                                    renderTo: target\n                                });\n                            }\n                            Ext.each(this.landingPageButtons, function(btn) {\n                                Ext.create({\n                                    xtype: 'spacer',\n                                    width: 25,\n                                    renderTo: target\n                                });\n                                Ext.create(Ext.applyIf(btn, {\n                                    xtype: 'button',\n                                    cls: 'q-btn-blue-dark',\n                                    renderTo: target\n                                }));\n                            }, this);\n                        }\n                    }\n                })\n            ],\n            scope: this\n        },cfg));\n\n        this.on('activate', function() { this.doLayout(); this.refreshDashboard(); }, this);\n        this.addEvents(\n            /**\n             * @event\n             * Fires when one of the tile chart points is clicked.\n             * Requires that {@link #enablePointClick is true.\n             * @param {portal.dashbopard.v2.DashbopardPanel} this\n             * @param {portal.customdashboard.portlet.PortletChart} chart\n             * @param {String} query The chart's configured search query.\n             * @param {Object} data An object containing the data of the clicked point.\n             * where the keys are field name(s) and the values are field value(s).\n             */\n            'chartpointclick',\n            /**\n             * @event dashboardload\n             * Fires when a dashboard is loaded.\n             * @param {portal.dashbopard.v2.DashbopardPanel} this\n             * @param {Object} dashboard The dashboard object.\n             */\n            'dashboardload'\n        );\n    };\n\n    Ext.extend($cls, Ext.Container, {\n        afterRender: function() {\n            $cls.superclass.afterRender.apply(this, arguments);\n\n            if (this.autoLoadDashboard) {\n                this.showMask();\n            }\n\n            // hack to resize title container layout when toolbar is hidden/shown to manage whitespace\n            this.toolbar.on({\n                'hide': function(tb) {\n                    this.titleCt.height = 60;\n                    this.doLayout();\n                },\n                'show': function(tb) {\n                    this.titleCt.height = 94;\n                    this.doLayout();\n                },\n                scope: this\n            });\n\n            new Ext.util.DelayedTask(function(){\n                this.displayOverlay();\n            }, this).delay(500);\n\n            Qx.DateUtils.FriendlyDateTime.startUpdating(); // keep cache timestamps updated\n        },\n\n        /**\n         * Shows the loading mask.\n         */\n        showMask: function() {\n            this.el.mask($L('275ca289-97ea-4f91-8758-244424e34613', 'Loading dashboard...'), 'x-mask-loading');\n            this.on('resize', this.showMask, this); // recenters mask\n        },\n\n        /**\n         * Hides the loading mask.\n         */\n        hideMask: function() {\n            this.el.unmask();\n            this.un('resize', this.showMask, this);\n        },\n\n        /**\n         * Load a dashboard from a combo selection\n         */\n        loadDashboard: function(ctn, rec) {\n            if (rec) {\n                var config = null;\n                try {\n                    config = this.encodeDashboardConfig(Ext.decode(rec.config));\n                } catch (e) {\n                    // invalid JSON config\n                    this.dashboardSelector.clear();\n                    this.unloadDashboard();\n                    Qx.notification.Notifier.error($L('f172c483-9a55-4cd7-8e09-8e6f0e6c65b0', 'Dashboard Error'), $L('cdec1486-ff14-45b0-a774-dbedb42044ee', 'An error occurred while loading the dashboard: The dashboard configuration is corrupt and cannot be loaded. Please contact your account manager.'));\n                }\n                var updatePermission = Passport.hasPermission(\"ASSET_MANAGEMENT.DASHBOARD.EDIT\");\n                var destroyPermission = Passport.hasPermission(\"ASSET_MANAGEMENT.DASHBOARD.DELETE\");\n                var createPermission = Passport.hasPermission(\"ASSET_MANAGEMENT.DASHBOARD.CREATE\");\n                if (config) {\n                    if (this.dashboardPermissions) {\n                        this.allow = Ext.apply(this.allow,{\n                            create: createPermission,\n                            destroy: createPermission ? (rec.createbByUserId === Passport.user.uuid || destroyPermission) : destroyPermission,\n                            update: createPermission? (rec.createbByUserId === Passport.user.uuid || updatePermission) : updatePermission\n                        });\n                    }\n\n                    if (this.dashboardPermissions) {\n                      this.permissionCheck();\n                    }\n                    this.dashboard = rec;\n                    this.emptyNotice.hide();\n                    this.filterContainer.show();\n                    this.refreshContainer.show();\n                    this.toolbar.show();\n                    this.mosaic.show();\n                    this.updateFilterVisibility();\n                    this.mosaic.load(config);\n                    this.fireEvent('dashboardload', this, this.dashboard);\n                }\n                this.dashboardService.getDashboard(this.dashboard.id, {\n                    scope: this,\n                    success: function(data) {\n                        this.dashboard.tags = data.tags;\n                    },\n                    failure: function(){return false;}\n                });\n            } else {\n                this.unloadDashboard();\n            }\n            this.hideMask();\n        },\n\n        /**\n         * Clean up dashboard workspace\n         */\n        unloadDashboard: function() {\n            this.mosaic.hide();\n            this.mosaic.clear();\n            this.toolbar.hide();\n            this.filterContainer.hide();\n            this.refreshContainer.hide();\n            this.emptyNotice.show();\n        },\n\n        /**\n         * Refresh dashboard contents\n         * @return void\n         */\n        refreshDashboard: function(force, invalidateCache) {\n            if (!this.hidden && this.mosaic.rendered === true) {\n                var filters = this.filterContainer.getFilterValues();\n                var mosaicArea = this.mosaic.el.dom.offsetHeight;\n                Ext.each(this.mosaic.tiles, function(tile) {\n                    if(!tile.loaded || force) {\n                        var yOffset = tile.el.getOffsetsTo(this.mosaic.el)[1] - mosaicArea;\n                        if (yOffset < -30 && yOffset > (30 - mosaicArea - tile.el.getHeight())) {\n                            var chart = tile.contents[0];\n                            chart.setFilters(filters, tile.invalidateCache || invalidateCache);\n                            tile.loaded = true;\n                            tile.invalidateCache = false;\n                        } else if (force) {\n                            // tile is out of view but we've requested a forced refresh,\n                            // this will ensure the widget is reloaded when scrolled into view\n                            tile.loaded = false;\n                            tile.invalidateCache = true;\n                        }\n                    }\n                }, this);\n            }\n        },\n\n        /**\n         * Refresh a single tile\n         */\n        refreshTile: function(tile, invalidateCache) {\n            var filters = this.filterContainer.getFilterValues();\n            var chart = tile.contents[0];\n            chart.setFilters(filters, invalidateCache);\n        },\n        permissionCheck: function() {\n          this.toolbar.removeAll();\n          this.toolbar.addItem([{\n              cls: 'qx-btn-filter',\n              text: $L('5ee0da8f-6319-4a09-8e82-276844ea54e0', 'Actions'),\n              menu: {\n                  cls: 'qx-menu',\n                  shadow: false,\n                  showSeparator: false,\n                  hideBorders: true,\n                  items: [{\n                      text: $L('5901f6a7-2cf0-4560-ad09-72a6018c35b4', 'Configure Dashboard'),\n                      handler: this.editDashboard,\n                      hidden: !this.allow.update,\n                      scope: this\n                  }, {\n                      text: $L('afc47b8e-98e3-4980-8e88-46e24abfc36f', 'Set as Default Dashboard'),\n                      handler: this.makeDefault,\n                      scope: this\n                  }].concat(this.allow.create ? ['-', {\n                      text: $L('155bf2af-c14e-41e6-b55d-cac02dfd32b5', 'Create Template from this Dashboard'),\n                      handler: this.createNewDashboardTemplate,\n                      scope: this\n                  }] : []).concat(this.allow.create ? ['-', {\n                      text: $L('ab593bfa-cfc1-438b-81ac-82d10964d8a2', 'Create New Dashboard'),\n                      handler: this.createNewDashboard,\n                      scope: this\n                  }] : []).concat(this.allow.destroy ? ['-', {\n                      text: $L('a509efd5-73bb-46bf-926f-2a3f2427ad55', 'Delete this Dashboard'),\n                      handler: this.removeDashboard,\n                      scope: this\n                  }] : []).concat(this.allow.update ? ['-',{\n                      text: $L('000caadd-ee13-4e23-857d-7821612b3ede', 'Print Dashboard'),\n                      handler: this.printDashboard,\n                      scope: this\n                  }]: []).concat(this.allow.create || this.allow.update ? ['-'] : []).concat(this.allow.create ? [{\n                      text: $L('7d98b86d-db7f-4e52-97de-9aeb8be516cd', 'Export this Dashboard'),\n                      handler: this.exportDashboard,\n                      scope: this\n                    }, {\n                      text: $L('bb6b8392-9eb1-4621-9639-99536b291e10', 'Import New Dashboard'),\n                      handler: this.importDashboard,\n                      scope: this\n                    }] : []).concat(this.allow.update ? [{\n                      text: $L('29b7c274-9c11-4956-a64c-9f8093408619', 'Import New Widget'),\n                      handler: this.importWidget,\n                      scope: this\n                    }] : []).concat(['-',{\n                      text: $L('Migrate Dashboard to UD'),\n                      handler: this.migrateToUD,\n                      hidden: !Passport.user.superuser,\n                      scope: this\n                  }])\n              },\n              scope: this\n          }, { xtype: 'tbspacer', width: 10 }, {\n              cls: 'qx-btn-filter',\n              text: $L('4eed5168-2cc4-4e77-a56d-4729e5d2beda', 'Add Widget'),\n              handler: this.addNewWidget,\n              hidden: !this.allow.update,\n              scope: this\n          }]);\n          this.toolbar.doLayout();\n          this.mosaic.tileDefaultConfig = {\n              actions: this.allow.update ? [{\n                  text: $L('a2fcaf15-8484-4fd8-81c3-1c1f8208bc3f', 'Configure Widget'),\n                  handler: function() {\n                      this.tile.mosaic.unzoomActiveTile();\n                      var dashboard = this.tile.mosaic.parent;\n                      dashboard.editWidget(this.tile);\n                  }\n              }, {\n                  text: $L('b7db7431-165d-4087-94ee-150b4d6d019d', 'Refresh Widget'),\n                  handler: function() {\n                      var dashboard = this.tile.mosaic.parent;\n                      dashboard.refreshTile(this.tile, true);\n                  }\n              },\"-\", {\n                  text: $L('31787a64-a163-4ece-9e67-41ba76437d4d', 'Create Template from this Widget'),\n                  handler: function(menu) {\n                      this.mosaic.unzoomActiveTile();\n                      this.createNewWidgetTemplate(menu);\n                  },\n                  scope: this\n              },\"-\", {\n                  text: $L('de9847b5-3cee-474c-877f-31ae8b654f11', 'Export this Widget'),\n                  handler: function(menu) {\n                      this.mosaic.unzoomActiveTile(menu);\n                      this.exportWidget(menu.tile);\n                  },\n                  scope: this\n              }, '-', {\n                  text: $L('9e3cfeea-d77e-4711-9301-fdc8861768d6', 'Remove Widget'),\n                  handler: function (menu) {\n                      this.removeWidget = true;\n                      this.mosaic.unzoomActiveTile();\n                      this.actions.unregisterTrendQueries([menu.tile]);\n                      menu.tile.mosaic.removeTile(menu.tile);\n                  },\n                  scope: this\n              }] : []\n          };\n          this.mosaic.readOnly = !this.allow.update;\n          this.allow.update ? this.mosaic.showAddTileButton() : this.mosaic.hideAddTileButton();\n          this.mosaic.doLayout();\n        },\n        /**\n         * Open the new widget dialog\n         */\n        addNewWidget: function() {\n            this.wizard = new portal.customdashboard.dialog.NewWidgetWizard({\n                dashboardService: this.dashboardService,\n                dashboardTemplateCategories: this.dashboardTemplateCategories,\n                widgetTemplateCategories: this.widgetTemplateCategories,\n                widgetCfg: this.widgetCfg,\n                tableColumnHeaderRenderer: this.tableColumnHeaderRenderer,\n                listColumnRenderer: this.listColumnRenderer,\n                searchTokens: this.searchTokens,\n                pivotTokens: this.pivotTokens,\n                listColumns: this.listColumns,\n                searchHelpUrl: this.searchHelpUrl,\n                isCreateWidget: true,\n                listeners: {\n                    scope: this,\n                    submit: function(dlg, data) {\n                      var titleIconCls = 'qx-icon-graph-small qx-icon-graph-' + this.getTileIconCls(data.chartType);\n                        var filters = this.filterContainer.getFilterValues();\n\n                        this.tile = this.mosaic.addTile({\n                          title: this.getTileTitle(data.title, data.chartType, data.enableTrending),\n                          titleIconCls: titleIconCls,\n                          state: data,\n                          contents: [new portal.customdashboard.portlet.PortletChart({\n                              chartType: data.chartType,\n                              dashboardService: this.dashboardService,\n                              tableColumnHeaderRenderer: this.tableColumnHeaderRenderer,\n                              listColumnRenderer: this.listColumnRenderer,\n                              enablePointClick: true,\n                              filters: filters,\n                              listeners: {\n                                  scope: this,\n                                  load: function(chart, data) {\n                                      this.updateTileResultsRefreshDate(this.tile, data.timestamp);\n                                  }\n                              }\n                          })],\n                          listeners: {\n                              scope: this,\n                              resize: function(ctn, adjW, adjH, rawW, rawH) {\n                                  ctn.contents[0].refresh(adjW, adjH);\n                              }\n                          }\n                        });\n\n                    }\n                }\n            });\n            this.wizard.show();\n            return this.wizard;\n        },\n\n        /**\n         * Open up the edit widget dialog to configure it\n         */\n        editWidget: function(tile) {\n            this.dashboardService.getDashboard(this.dashboard.id, {\n                scope: this,\n                success: function(data) {\n                    this.dashboard.tags = data.tags;\n                },\n                failure: function(){return false;}\n            });\n            this.wizard = new portal.customdashboard.dialog.EditWidgetDialog({\n                tile: tile,\n                widgetCfg: this.widgetCfg,\n                dashboardService: this.dashboardService,\n                searchTokens: this.searchTokens,\n                pivotTokens: this.pivotTokens,\n                listColumns: this.listColumns,\n                tableColumnHeaderRenderer: this.tableColumnHeaderRenderer,\n                listColumnRenderer: this.listColumnRenderer,\n                searchHelpUrl: this.searchHelpUrl,\n                isEditWidget: true,\n                listeners: {\n                    scope: this,\n                    submit: function(dlg, data) {\n                      if (data.enableTrending && !tile.state.enableTrending && tile.row.height < 300) {\n                          if ((tile.row.items.getCount() - 1 / 2) > 2) { // more than two tiles in this row\n                              // enforce min height of 300px for rows that now have trend widgets\n                              tile.row.height = 300;\n                              tile.row.el.setHeight(300);\n                              this.mosaic.doLayout();\n                          }\n                        }\n                         tile.prevState = tile.state;\n                         tile.state = data;\n                         tile.title = data.title;\n                        this.onUpdate(data);\n\n                    }\n                }\n            }).show();\n        },\n\n        getTileIconCls: function(type) {\n            type = type.replace('timeline', 'line');\n            return 'qx-icon-graph-small qx-icon-graph-' + type;\n        },\n\n        /**\n         * Open creation dashboard dialog\n         */\n        createNewDashboard: function() {\n            this.el.mask();\n            this.actions.create({\n                close: function(){\n                    this.el.unmask();\n                },\n                submit: this.loadLocalData,\n                scope: this\n            },\n            { templates: this.templates, enableTags: this.enableScopeTags, filterCfg: this.filterCfg });\n        },\n\n        /**\n         * Open new template creation dialog\n         */\n        createNewDashboardTemplate: function() {\n            this.el.mask();\n            var filters = Ext.decode(this.dashboard.config).filters || {};\n            var config = Ext.encode(Ext.apply(this.getCleanDashboardConfig(), { filters: filters }));\n            this.actions.createDashboardTemplate({\n                scope: this,\n                close: function() {\n                    this.el.unmask();\n                }\n            }, {\n                config: config\n            });\n        },\n\n        /**\n         * Open edit dashboard dialog\n         */\n        editDashboard: function() {\n            this.el.mask();\n            this.actions.edit(this.dashboard, {\n                close: function(){\n                    this.el.unmask();\n                },\n                submit: this.loadLocalData,\n                scope: this\n            },\n            { enableTags: this.enableScopeTags, filterCfg: this.filterCfg });\n        },\n\n        exportDashboard: function() {\n          this.actions.export(\"dashboard\", this.dashboard, {\n              close: function(){\n                  this.el.unmask();\n              },\n              exportfailure:  function() {\n                  Qx.notification.Notifier.error($L('fd8f8dba-3204-4468-a55b-86db3bd893aa', \"Export Dashboard\"), $L('60a91acd-db94-4a7e-b45e-e6a095aedc81', \"An error occurred while exporting the dashboard.\"));\n              },\n              scope: this\n          })\n        },\n\n        exportWidget: function(tile) {\n          /* introduced .reduce method to support IE */\n          var obj = [];\n          obj.push(tile);\n          var clonedTile = obj.reduce(function (r, o) {\n                Object.keys(o).forEach(function (k) {\n                  r[k] = o[k];\n                });\n             return r;\n         },{});\n\n          this.cleanProps(clonedTile, this.tileTemplateProps);\n          clonedTile.state = this.cleanProps(clonedTile.state, this.tileStateTemplateProps);\n          if(clonedTile.state.query) {\n              clonedTile.state.query = Ext.util.Format.htmlDecode(clonedTile.state.query);\n          }\n          if(clonedTile.state.query2) {\n              clonedTile.state.query2 = Ext.util.Format.htmlDecode(clonedTile.state.query2);\n          }\n          this.actions.export(\"widget\", clonedTile, {\n              close: function(){\n                  this.el.unmask();\n              },\n              exportfailure:  function() {\n                  Qx.notification.Notifier.error($L('c5760544-64f2-42b9-94f1-a6c2dca568bd', \"Export Widget\"), $L('c58b4bcf-7833-4313-8144-3b6dac69e67b', \"An error occurred while exporting the widget.\"));\n              },\n              scope: this\n          });\n        },\n\n        importDashboard: function() {\n          this.actions.import(\"dashboard\", this.dashboard.id, {\n              close: function(){\n                  this.el.unmask();\n              },\n              importcomplete: function(dashboard) {\n                  Qx.notification.Notifier.success($L('e1618b6d-adc0-4309-9924-0b0311cc9586', \"Import Dashboard\"), $L('a996df12-e1fe-45de-86d7-7cdb7b25a500', \"Dashboard imported successfully.\"));\n                  this.loadLocalData(dashboard);\n              },\n              importfailure: function() {\n                  Qx.notification.Notifier.error($L('7eb68e3f-5d7a-492f-a382-cc02044f8f43', \"Import Error\"), $L('41bb687c-fd0e-4202-a4ac-05d138656884', \"An error occurred while importing the dashboard.\"));\n              },\n              scope: this\n          })\n        },\n\n        importWidget: function() {\n          this.actions.import(\"widget\", this.dashboard.id, {\n              close: function(){\n                  this.el.unmask();\n              },\n              importcomplete: function(dashboard) {\n                  Qx.notification.Notifier.success($L('0c5e5518-8506-4c93-b5e4-d2fe4a8a0409', \"Import Widget\"), $L('60fcb30f-828e-4eca-ad8b-64acdf6e7f9e', \"Widget imported successfully.\"));\n                  this.loadDashboard(this, dashboard);\n                  var row = this.mosaic.items.get(this.mosaic.items.length - 3);\n                  var tile = row.items.get(row.items.length - 2); // gets the last tile, which is the one that was just imported\n                  this.mosaic.el.scrollTo('top', tile.el.getOffsetsTo(this.mosaic.el)[1]);\n                  this.mosaic.getScroller().syncThumbPosition();\n                  this.editWidget(tile);\n              },\n              scope: this\n          })\n        },\n\n        printDashboard: function() {\n            window.print();\n        },\n\n        migrateToUD: function() {\n            Ext.Ajax.request({\n                url: '/ud/rest/1.0/dashboards/migrate-to-ud',\n                method: 'POST',\n                jsonData: '[\"' + this.dashboard.uuid +'\"]',\n                success: function () {\n                    Qx.notification.Notifier.success($L(\"Migrate Dashboard to UD\"), $L(\"Dashboard migrated successfully. You can access the migrated dashboard under Unified Dashboard.\"));\n                },\n                failure: function () {\n                    Qx.notification.Notifier.error($L(\"Migrate Dashboard to UD\"), $L(\"An error occurred while migrating the dashboard to UD. Contact Qualys Support.\"));\n                }\n            });\n        },\n\n        /**\n         * Open new widget template creation dialog\n         */\n        createNewWidgetTemplate: function(item) {\n            // TODO get proper reference to tile\n            var tile = item.findParentByType(\"qxtile\");\n            var config = this.cleanProps(Ext.apply({}, tile.state), this.tileStateTemplateProps);\n            Ext.apply(config, { title: tile.title });\n            delete config.filters;\n            this.el.mask();\n            this.actions.createWidgetTemplate({\n                scope: this,\n                close: function() {\n                    this.el.unmask();\n                }\n            }, {\n                config: Ext.encode(config)\n            });\n        },\n\n        loadLocalData: function(dashboard) {\n            this.dashboard = dashboard;\n            var selected = this.dashboardSelector.getSelectedDashboard();\n            if (selected) {\n                selected.set('title', dashboard.title);\n                selected.commit();\n            }\n            if (dashboard.isDefault) {\n                this.dashboardSelector.setDefaultDashboard(dashboard.id);\n            }\n            this.dashboardSelector.setSelectedDashboard(dashboard.id, true, true);\n            this.updateFilterVisibility();\n            this.refreshDashboard();\n        },\n\n        /**\n         * Open remove dashboard confirmation\n         */\n        removeDashboard: function() {\n            if (this.dashboard.isDefault) {\n                new portal.core.dialog.ErrorDialog($L('4656153e-478e-41c7-87d1-c492e5ee3307', 'Delete Dashboard Error'), $L('6519512b-e041-4e34-99e4-1beb2ea32369', 'The default dashboard cannot be deleted.')).show();\n            } else {\n                this.actions.remove([this.dashboard.id], {\n                    complete: function (panel) {\n                        this.actions.unregisterTrendQueries(this.mosaic.tiles);\n                        this.dashboardSelector.removeDashboard(this.dashboard.id);\n                        this.unloadDashboard();\n                        this.dashboardSelector.selectDefaultDashboard();\n                    },\n                    scope: this\n                }, this);\n            }\n        },\n\n        /**\n         * Called when a new tile is added\n         */\n        initTile: function(mosaic, tile) {\n            var tileChart = tile.contents[0];\n            tileChart.setConfig(tile.state);\n            tileChart.tile = tile;\n            tileChart.reload();\n            tile.loaded = true;\n            tile.setTitle(this.getTileTitle(tile.state.title, tile.state.chartType, tile.state.enableTrending, true));\n            tile.setTitleIconCls(this.getTileIconCls(tile.state.chartType));\n\n        },\n\n        onTileAdd: function(mosaic, tile) {\n            this.initTile(mosaic, tile);\n            this.initTileEvents(tile);\n            if (tile.state) {\n                if (tile.state.chartType === 'threat') {\n                    // hide the \"configure\" menu item since no config options are available for threat feeds\n                    var configure = tile.getActionMenuItem($L('a2fcaf15-8484-4fd8-81c3-1c1f8208bc3f', 'Configure Widget'));\n                    if (configure) {\n                        configure.disable();\n                    }\n                    // hide the \"export\" menu item\n                    var exportWidget = tile.getActionMenuItem($L('de9847b5-3cee-474c-877f-31ae8b654f11', 'Export this Widget'));\n                    if (exportWidget) {\n                        exportWidget.disable();\n                    }\n                    // hide the \"create\" menu item\n                    var create = tile.getActionMenuItem($L('31787a64-a163-4ece-9e67-41ba76437d4d', 'Create Template from this Widget'));\n                    if (create) {\n                        create.disable();\n                    }\n                }\n            }\n        },\n\n        initTileEvents: function(tile) {\n            var tileChart = tile.contents[0];\n            tileChart.on('pointclick', function(portlet, query, data) {\n                this.fireEvent('chartpointclick', portlet, query, data);\n            }, this);\n        },\n\n        /**\n         * Make current dashboard the default dashboard\n         */\n        makeDefault: function() {\n            if (Ext.isDefined(this.dashboard)) {\n                this.dashboardService.setDefaultDashboard(this.dashboard.id, true, {\n                    scope: this,\n                    success: function(data) {\n                        shared.Notifier.success($L('99f5c1d0-1307-432a-8cb2-1465b66fd8c4', 'Dashboard Update'), $L('9f8c44e2-06f5-4870-899b-ec6ae1f5af60', 'Dashboard set as default.'));\n                        this.dashboard.isDefault = true;\n                        this.dashboardSelector.setDefaultDashboard(this.dashboard.id);\n                    },\n                    failure: function(err, msg) {\n                        new portal.core.dialog.ErrorDialog($L('2e05666e-a6fa-4354-8e39-d9f9b253ef94', 'Dashboard Save Error'), [\n                            $L('f5808fa4-fdd9-42e4-aaec-66b7b8ced7b6', 'Could not save changes.')\n                        ].join('<br/>')).show();\n                    }\n                });\n            }\n        },\n        callUpdateDashboard: function(newCfg) {\n          this.dashboardService.updateDashboard({id: this.dashboard.id, config: newCfg}, {\n            scope: this,\n            success: function(data) {\n              this.dashboard = data;\n              this.dashboardSelector.getSelectedDashboard().set('config', data.config);\n              this.removeWidget= false;\n            },\n            failure: function(err, msg) {\n              new portal.core.dialog.ErrorDialog($L('1d2bebce-b208-4017-8585-2fd9f7d6fbe7', 'Dashboard Save Error'), [\n                  $L('6c86e1fa-64f8-4126-8ae1-f3dc846861b4', 'Could not save changes.')\n              ].join('<br/>')).show();\n            }\n          });\n        },\n\n        /**\n         * Called whenever the mosaic changes\n         */\n        onUpdateWidget: function(widgetData) {\n          this.dashboardService.getDashboard(this.dashboard.id, {\n                scope: this,\n                success: function(data) {\n                    this.dashboard.tags = data.tags;\n                    this.onUpdate(widgetData, this.dashboard.tags)\n                },\n                failure: function(){return false;}\n            });\n        },\n        onUpdate: function(widgetData, dashTags) {\n            if (Ext.isDefined(this.dashboard)) {\n                var filters = {};\n                var newCfg = Ext.encode(Ext.apply(this.getCleanDashboardConfig(), { filters: filters }));\n                if (this.dashboard.preserveFilters) { // TODO: will always be falsey since persisting of filters is not yet implemented\n                    // be sure to preserve filters since mosaic does not track them\n                    filters = this.filterContainer.getFilterValues();\n                }\n                if (this.removeWidget) {\n                    this.callUpdateDashboard(newCfg);\n                }else {\n                    if (this.wizard){\n                      this.isUnique = false;\n                      if (this.wizard.isCreateWidget && this.wizard.systemTemplateTitle) {\n                        this.widgetTitle = this.wizard.systemTemplateTitle;\n                      }else if (this.wizard.isCustomWidget===false) {\n                        this.widgetTitle = widgetData.title;\n                      }else {\n                        var val = this.wizard.form.form.titleField;\n                        try {\n                            this.widgetTitle = val.getValue() ? val.getValue(): val.value;\n                        } catch (e) {\n                            this.callUpdateDashboard(newCfg);\n                        }\n                      }\n                    }\n                    var tags = dashTags || this.dashboard.tags;\n                    var tagIds = Ext.pluck(tags, \"id\");\n                    this.dashboardService.createOrUpdateWidget({id: this.dashboard.id, config: newCfg, tags:tagIds }, this.widgetTitle, {\n                        scope: this,\n                        success: function(data, response) {\n                          if (this.wizard.isEditWidget) {\n                            this.initTile(this, this.wizard.tile);\n                          }\n                          if (this.wizard.isCreateWidget && this.isUnique || this.wizard.systemTemplateTitle && this.isUnique) return false;\n                          else {\n                            this.dashboard = data;\n                            this.dashboardSelector.getSelectedDashboard().set('config', data.config);\n                            this.wizard.close();\n                          }\n                        },\n                        failure: function(msg, err) {\n                            switch (err.exception.className) {\n                                case \"UniquenessException\":\n                                if (this.wizard) {\n                                    this.wizard.form.form && this.wizard.form.form.titleField.markInvalidAsDuplicate();\n                                    if (!this.wizard.isCustomWidget && this.wizard.systemTemplateTitle) {\n                                      this.tile.mosaic.removeTile(this.tile);\n                                      this.isUnique = true;\n                                      new portal.core.dialog.ErrorDialog($L('aad575b4-ceed-4a5a-9277-07de601863bf', 'Duplicate Widget Title'), ['<div class=\"duplicate-error\" style=\"font-weight:bold\">' +$L('2f291b01-bb88-434f-8961-7618a0f7dce8', 'Cannot add duplicate widget to dashboard!') +'</div><div class=\"duplicate-error\">'+$L('76b5e28f-3022-4ff0-81c6-d1087cd5adab', 'Widget with the title \"'+this.wizard.systemTemplateTitle+'\" already exists in the dashboard')+'</div>'].join('<br/>')).show();\n                                    }else if (this.wizard.isCreateWidget) {\n                                      this.tile.mosaic.removeTile(this.tile);\n                                      this.isUnique = true;\n                                    }\n                                    if (this.wizard.isEditWidget && this.wizard.tile){\n                                      this.wizard.tile.state = this.wizard.tile.prevState;\n                                    }\n                                  }\n                                break;\n                                default:\n                                new portal.core.dialog.ErrorDialog($L('ffb8bd8a-82bc-44d6-a4f5-778311f8b33d', 'Dashboard Save Error'), [$L('019e35dc-3537-489e-81fc-77eab4761955', 'Could not save changes.')].join('<br/>')).show();\n                                break;\n                            }\n                        }\n                    });\n                }\n            }\n        },\n\n        /**\n         * Clean up dashboard data before being passed to DWR\n         * This is done as we pass a lot of crap to get components to work together within that config\n         */\n        getCleanDashboardConfig: function() {\n            var cfg = this.mosaic.save();\n            this.cleanProps(cfg, [\"rows\", \"filters\"]);\n            Ext.each(cfg.rows, function(row) {\n                this.cleanProps(row, [\"height\", \"tiles\"]);\n                Ext.each(row.tiles, function(tile) {\n                    this.cleanProps(tile, this.tileTemplateProps);\n                    tile.state = this.cleanProps(tile.state, this.tileStateTemplateProps);\n                }, this);\n            }, this);\n            return cfg;\n        },\n\n        cleanProps: function(obj, props) {\n            for (var prop in obj) {\n                if (props.indexOf(prop) < 0) {\n                    delete(obj[prop]);\n                }\n            }\n            return obj;\n        },\n\n        /**\n         * HTML encodes certain unsanitized props for display.\n         */\n        encodeDashboardConfig: function(cfg) {\n            if (!cfg._encoded) {\n                Ext.each(cfg.rows, function(row) {\n                    Ext.each(row.tiles, function(tile) {\n                        Ext.each(this.tileEncodeProps, function(prop) {\n                            if (tile.state && tile.state[prop]) {\n                                // decode to convert hex encoded chars to HTML, then HTML reencode to our DB standards\n                                tile.state[prop] = Ext.util.Format.htmlEncode(Ext.util.Format.htmlDecode(tile.state[prop]));\n                            }\n                            if (tile[prop]) {\n                                // decode to convert hex encoded chars to HTML, then HTML reencode to our DB standards\n                                tile[prop] = Ext.util.Format.htmlEncode(Ext.util.Format.htmlDecode(tile[prop]));\n                            }\n                        }, this);\n                    }, this);\n                }, this);\n                cfg._encoded = true;\n            }\n            return cfg;\n        },\n\n        /**\n         * Called when a new dashboard has been loaded. Basically load each chart config and redraw each chart.\n         */\n        onLoad: function(mosaic) {\n            var filters = this.filterContainer.getFilterValues();\n            Ext.each(mosaic.tiles, function(tile) {\n                var state = tile.state;\n                tile.state.title = tile.title || tile.state.title;\n                var chart = new portal.customdashboard.portlet.PortletChart(Ext.apply(state, {\n                    dashboardService: this.dashboardService,\n                    filters: filters,\n                    selectedDashboard: this.dashboard,\n                    tile: tile,\n                    tableColumnHeaderRenderer: this.tableColumnHeaderRenderer,\n                    listColumnRenderer: this.listColumnRenderer,\n                    enablePointClick: true,\n                    listeners: {\n                        load: function(chart, data) {\n                            this.updateTileResultsRefreshDate(tile, data.timestamp);\n                        },\n                        scope: this\n                    }\n                }));\n                tile.contents.push(chart);\n                tile.add(chart);\n                tile.setTitle(this.getTileTitle(tile.title || tile.state.title, state.chartType, state.enableTrending));\n                tile.setTitleIconCls(this.getTileIconCls(tile.state.chartType));\n                tile.addListener('resize', function(ctn, adjW, adjH, rawW, rawH) {\n                    ctn.contents[0].refresh(adjW, adjH);\n                }, this);\n                this.initTileEvents(tile);\n            }, this);\n            this.doLayout();\n            this.refreshDashboard();\n        },\n\n        /**\n         * Display overlay information when loading a dashboard for the first time\n         */\n        displayOverlay: function() {\n            if (this.overlay && !this.tips) {\n                this.tips = true;\n                if (Passport.hasAccessedSection(PageFrame.module.toUpperCase(), this.sectionName) === false) {\n                    this.el.addClass('dashboard-overlay-active');\n                    new Qx.help.TipsOverlay(Ext.apply(this.overlay, {\n                        cls: 'dashboard-overlay',\n                        listeners: {\n                            'dismiss': function() {\n                                this.el.removeClass('dashboard-overlay-active');\n                                Passport.confirmSectionAccess(PageFrame.module.toUpperCase(), this.sectionName);\n                            },\n                            scope: this\n                        }\n                    }));\n                }\n            }\n        },\n\n        /**\n         * Gets the tile title, appended with any configured suffix.\n         */\n        getTileTitle: function(title, chartType, enableTrending, encode) {\n            // if (this.dataVisuCfg[chartType] && this.dataVisuCfg[chartType].titleSuffix) {\n            //     return String.format('{0}<span class=\"dashboard-v2-tile-title-suffix\">({1})</span>', title, this.dataVisuCfg[chartType].titleSuffix);\n            // }\n            var tileTitle = (this.trendingFeatureEnabled && enableTrending) || chartType !== portal.asset.v2.Constants.dashboard.widgetType.COUNT ? title : \"\";\n            if (encode) {\n                return Ext.util.Format.htmlEncode(Ext.util.Format.htmlDecode(tileTitle));\n            } else {\n                return tileTitle;\n            }\n        },\n        /**\n         * Updates the tile title to show the time that the data was refreshed.\n         */\n        updateTileResultsRefreshDate: function(tile, timestamp) {\n                dateCt = tile.el.child('.dashboard-widget-refresh-date'),\n                html = $L('6f3f0115-a911-42e1-a802-ae4ee29c7c06', 'Last refreshed $1', Qx.DateUtils.FriendlyDateTime.updatableFormat(timestamp));\n            if (!dateCt) {\n                tile.el.createChild({\n                    tag: 'span',\n                    cls: 'dashboard-widget-refresh-date',\n                    html: html\n                });\n            } else {\n                dateCt.update(html);\n            }\n        },\n\n        createFilterItems: function() {\n            var filterItems = [];\n            Ext.iterate(this.filterCfg, function(name, cfg) {\n                if (cfg !== false) {\n                    filterItems.push(Ext.apply(cfg.editor, {\n                        name: cfg.name || name,\n                        persistent: cfg.persistent || false,\n                        hidden: true,\n                        width: cfg.width || 310,\n                        margins: '0 10 0 0',\n                        listeners: Ext.apply(cfg.editor.listeners || {}, {\n                            filterchange: function() {\n                                if (this.dashboard.preserveFilters) {\n                                    this.onUpdate();\n                                }\n                                this.refreshDashboard(true);\n                            },\n                            scope: this\n                        })\n                    }));\n                }\n            }, this);\n            return filterItems.sort(function(a, b) {\n                // make the datetime filter the last filter\n                return a.name === 'datetime' ? 1 : 0; // TODO: accommodate filter ordering config option\n            });\n        },\n\n        /**\n         * @private\n         * Updates dashboard filter visibility.\n         */\n        updateFilterVisibility: function() {\n            var filters = Ext.decode(this.dashboard.config).filters;\n            var showFilters = false;\n            this.filterContainer.items.each(function(filter) {\n                if (filter.getXType() !== 'spacer') {\n                    var showFilter = (filters && filters[filter.name]) || filter.persistent;\n                    filter[showFilter ? 'show' : 'hide']();\n                    if (showFilter) {\n                        showFilters = true;\n                    }\n                }\n            });\n            this.filterContainer[showFilters ? 'show' : 'hide']();\n            this.filterContainer.doLayout();\n        },\n\n        onBeforeTileZoom: function() {\n            this.mosaic.getScroller().hide();\n        },\n\n        onTileUnzoom: function() {\n            this.mosaic.getScroller().show();\n        }\n    });\n})();\n;\n(function(){var B=Q.Util.namespace(\"portal.asset.v2.panel\");var A=B.AssetViewLearnMore=function(C){A.superclass.constructor.call(this,Ext.apply({title:$L(\"206af944-adc1-45bf-8cb1-612dac3e326b\",\"About AssetView\"),height:350,width:600,layout:{type:\"auto\"},cls:\"asset-view-learn-more\",modal:true,autoScroll:true,plugins:\"qxpanelscrollbar\",resizable:true,items:[{xtype:\"box\",cls:\"asset-view-learn-more-section\",html:'<div class=\"learn-more-header\"><b>'+$L(\"89816bf2-aca9-429e-af51-d461fc8bf905\",\"What is AssetView?\")+'</b></div><div class=\"learn-more-content\">'+$L(\"10e6192c-8566-4577-941b-1a474fc9c899\",\"Qualys AssetView is our free asset discovery and inventory service.\")+\"</div>\"},{xtype:\"box\",cls:\"asset-view-learn-more-section\",html:'<div class=\"learn-more-header\"><b>'+$L(\"1ab9f99b-5699-4fca-bd5c-eb933ba16859\",\"What do I get?\")+'</b></div><div class=\"learn-more-content\">'+$L(\"b626bbf3-805f-4707-9e60-057db4cf0023\",\"You'll get an asset inventory that is continuously up-to-date. Search your assets in seconds and get actionable data about services, file systems and registries.\")+\"</div>\"},{xtype:\"box\",cls:\"asset-view-learn-more-section\",html:['<div class=\"learn-more-header\"><b>'+$L(\"95e79cad-2147-4a0b-84ae-ab6e6d414aaa\",\"Quick look at how it works\")+'</b></div><div class=\"learn-more-content\"><ul><li>'+$L(\"43eff4f5-d7bc-4420-ad90-88180a6cfd9c\",\"You'll download and install agents on your host assets.\")+\"</li><li>\"+$L(\"af471921-aea7-4f82-88a7-17fa99499623\",\"Agents will perform asset discovery and connect back.\")+\"</li><li>\"+$L(\"c32d6679-af98-4b51-b20e-