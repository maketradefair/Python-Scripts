         this.invalidGroupByMsg.show();\n            this.invalidGroupByMsg.el.alignTo(this.rowsField.el, 'tl-bl', [ 123, 12 ], false);\n            if (fade) {\n                this.invalidGroupByMsg.el.fadeIn();\n            }\n        },\n        hideInvalidGroupByMsg: function() {\n            if (this.invalidGroupByMsg) {\n                this.invalidGroupByMsg.hide();\n            }\n        },\n        onRowsFieldValueChange: function(cmp, value) {\n            var re = /vulnerabilities.vulnerability/;\n            re.test(value) ? this.queryField.label.update($L('a07535f5-8763-4b16-997d-3c519e0c7fbd', \"Query\") + \" <span class='required'>*</span>\") : this.queryField.label.update($L('a07535f5-8763-4b16-997d-3c519e0c7fbd', \"Query\"));\n            re.test(value) ? this.queryFieldWarning.show() : this.queryFieldWarning.hide();\n            this.setColumnsFieldFilter();\n            var data = [value.data ? value.data.value : value];\n            if((this.columnsField.getValue() || []).length > 0) {\n                data.push(this.columnsField.getValue());\n            }\n            this.sortField.store.loadData(data);\n            if (data.indexOf(this.sortField.getValue()) === -1) {\n                this.sortField.setValue(\"count\");\n            }\n            this.fireEvent('valuechange', this);\n        },\n        onColumnsFieldValueChange: function(cmp, value) {\n            this.tokenFilters.setTokens(this.getGroupByFilterTokens());\n            var data = [value ? (value.data ? value.data.value : value) : value, this.rowsField.getValue()];\n            this.sortField.store.loadData(data);\n            if (data.indexOf(this.sortField.getValue()) === -1) {\n                this.sortField.setValue(\"count\");\n            }\n            this.fireEvent('valuechange', this);\n        },\n        onResultTypeValueChange: function() {\n            if (this.resultTypeField.getValue().inputValue === \"AGGREGATE\") {\n                this.listColumnsField.hide();\n                this.assetOrderField.hide();\n                this.sortField.show();\n                this.assetOrderDirField.show();\n                this.rowsField.show();\n                this.columnsField.show();\n                this.tokenFiltersLabel.show();\n                this.tokenFiltersNotice.show();\n                this.tokenFilters.show();\n                this.tokenFilters.setTokens(this.getGroupByFilterTokens());\n            } else { // LIST\n                this.listColumnsField.show();\n                this.assetOrderField.show();\n                this.sortField.hide();\n                this.assetOrderDirField.show();\n                this.rowsField.hide();\n                this.columnsField.hide();\n                this.tokenFiltersLabel.hide();\n                this.tokenFiltersNotice.hide();\n                this.tokenFilters.hide();\n            }\n            this.fireEvent(\"valuechange\", this);\n        },\n        setColumnsFieldFilter: function() {\n            // need to filter the columns / categories field based on whether a vuln token is selected\n            var row = this.rowsField.getValue(),\n                col = this.columnsField.getValue(),\n                isRowVulnToken = portal.asset.util.GroupByVulnsUtil.isVulnToken(row);\n            if ((isRowVulnToken && !portal.asset.util.GroupByVulnsUtil.isVulnToken(col)) ||\n                (!isRowVulnToken && portal.asset.util.GroupByVulnsUtil.isVulnToken(col)) ||\n                row == col) {\n                this.columnsField.clearValue();\n            }\n            this.columnsField.setStickyFilter(function(r) {\n                return r.get('value') !== row &&\n                    portal.asset.util.GroupByVulnsUtil.isVulnToken(r.get('value')) === isRowVulnToken;\n            });\n            this.tokenFilters.setTokens(this.getGroupByFilterTokens());\n        },\n        onDestroy: function() {\n            $cls.superclass.onDestroy.apply(this, arguments);\n          