  legendItemClick: function() {\n                                    self.firePointClickEvent({ series: this });\n                                    return false;\n                                }\n                            }\n                        },\n                        series: {\n                            cursor: this.enablePointClick ? 'pointer' : 'default'\n                        }\n                    }\n                }), \"column\", data, w, h);\n            } else {\n                this.addChart(Qx.chart.Highchart.Configs.get('bar', {\n                    chart: {\n                        marginBottom: !this.labels ? 150 : null,\n                        marginLeft: this.labels ? 100 : null\n                    },\n                    xAxis: {\n                        categories: data.categories,\n                        labels: {\n                            enabled: this.labels,\n                            formatter: function() {\n                                var v = Ext.util.Format.htmlEncode(this.value);\n                                return \"<span class='lbl-2-lines' ext:qtip='\" + v + \"'>\" + v + \"</span>\";\n                            }\n                        }\n                    },\n                    yAxis: {\n                        min: 0\n                    },\n                    plotOptions: {\n                        bar: {\n                            grouping: false,\n                            stacking: null,\n                            point: {\n                                events: {\n                                    click: function() {\n                                        self.firePointClickEvent(this);\n                                    }\n                                }\n                            },\n                            events: {\n                                legendItemClick: function() {\n                                    self.firePointClickEvent({ series: this });\n                                    return false;\n                                }\n                            }\n                        },\n                        series: {\n                            pointWidth: data.categories.length > 1 ? (height / (data.categories.length * 2)) : null,\n                            cursor: this.enablePointClick ? 'pointer' : 'default'\n                        }\n                    }\n                }), \"bar\", data, w, h);\n            }\n        },\n\n        addPieChart: function(data, w, h) {\n            var ordered = data.series;\n            // remove the Unknown values\n            if (!this.showEmpty) {\n                var empty = Qx.ArrayUtils.extract(ordered, function(o) {\n                    return (o.name === \"Unknown\" || o.name=== \"null\");\n                }, this);\n                ordered = Qx.ArrayUtils.subtract(ordered, empty);\n                if (ordered.length > this.limit) {\n                    ordered.pop();\n                }\n                if (ordered.length === 0) {\n                    this.showNoResultsText();\n                    return;\n                }\n            }\n            data.series = ordered;\n            // transform passed data so that it fits highcharts stuff\n            var arr = [],\n                self = this;\n            Ext.each(data.series, function(serie) {\n                arr.push([serie.name, serie.data[0]]);\n            });\n            var pieData = {\n                startDate: data.startDate,\n                endDate: data.endDate,\n                series: [{\n                    name: this.categories,\n                    data: arr\n                }]\n            };\n            this.addChart(Qx.chart.Highchart.Configs.get('donut', {\n                chart: {\n                    marginTop: this.labels ? 20 : null,\n                    marginRight: this.labels ? 20 : null,\n                    marginBottom: this.labels ? 20 : null,\n                    marginLeft: this.labels ? 20 : null\n                },\n                tooltip: {\n                    pointFormat: '{series.name}: <b>{point.percentage:.1f}%</b>'\n                },\n                plotOptions: {\n                    pie: {\n                        size: '83%',\n                        innerSize: this.donut ? '39%' : '0',\n                        point: {\n                            events: {\n                                click: function() {\n                                    self.firePointClickEvent(this);\n                                }\n                            }\n                        }\n                    },\n                    series: {\n                        dataLabels: {\n                            enabled: this.labels\n                        },\n                        cursor: this.enablePointClick ? 'pointer' : 'default',\n                        point: {\n                            events: {\n                                legendItemClick: function() {\n                                    self.firePointClickEvent(this);\n                                    return false;\n                                }\n                            }\n                        }\n                    }\n                }\n            }), \"pie\", pieData, w, h);\n        },\n\n        addChart: function(cfg, type, data, w, h, interval) {\n            if (Ext.isArray(data.series) && data.series.length > 0) {\n                this.chart = new Qx.chart.HighchartContainer({\n                    dynamicCategories: false,\n                    showLegend: this.legend,\n                    setSeriesData: function(series, data) {\n                        Ext.each(data, function(d, idx) {\n                            series[idx] = Ext.apply({\n                                name: d.name,\n                                data: d.data,\n                                color: d.color,\n                                type: type\n                            }, {});\n                        });\n                    },\n                    getLegendConfig: function() {\n                        var ct = this;\n                        return {\n                            align: 'right',\n                            verticalAlign: 'top',\n                            layout: 'vertical',\n                            x: -25,\n                            y: 25,\n                            borderWidth: 0,\n                            floating: type === 'column',\n                            itemMarginBottom: 5,\n                            labelFormatter: function() {\n                                var count = this.count || 0;\n                                if (!Ext.isDefined(this.count) && this.userOptions.data && this.userOptions.data.length) {\n                                    Ext.each(this.userOptions.data, function(ct) {\n                                      count += ct ? ct.count: ct;\n                                    });\n                                }\n                                return [\n                                    '<div class=\"qx-highchart-legend-item\"', (ct.enablePointClick ? 'style=\"cursor:pointer\"' : '') , '>',\n                                        Ext.util.Format.ellipsis(Ext.util.Format.htmlEncode(this.name), 48),\n                                        '<span class=\"qx-highchart-legend-item-count\">',\n                                            Ext.util.Format.number(count, '0,000'),\n                                        '</span>',\n                                    '</div>'\n                                ].join('');\n                            },\n                            symbolPadding: 10,\n                            symbolWidth: 12,\n                            symbolRadius: 2,\n                            useHTML: true\n                        };\n                    }.createDelegate(this),\n                    getTooltipConfig: function() {\n                        var ct = this;\n                        return {\n                            useHTML: true,\n                            formatter: function() {\n                                if (type === 'area') { // TODO\n                                    return portal.lm.Renderers.dashboard.timelineTooltip(new Date(this.x), new Date(this.x + interval), this.y);\n                                }\n                                return [\n                                    type === 'pie' ? this.point.name : Ext.util.Format.htmlEncode(this.series.name),\n                                    ': <b>',\n                                    Ext.util.Format.number(this.point[ct.forcePointVisibility ? 'count' : 'y'], '0,000'),\n                                    '</b>'\n                                ].join('');\n                            },\n                            style: {\n                                fontFamily: 'helvetica,arial,sans-serif'\n                            }\n                        };\n                    },\n                    forcePointVisibility: true,\n                    forcePointVisibilityTransform: function(type, data) {\n                        var values = [], minVal = 0;\n                        if (type === 'column' || type === 'bar') {\n                            Ext.each(data, function(d) {\n                                values.push(Ext.sum(d.data));\n                            });\n                            minVal = values.sort(function(a,b) {return a<b;})[0] * 0.025;\n                            Ext.each(data, function(d) {\n                                for (var i=0; i<d.data.length; i++) {\n                                    if (Ext.isNumber(d.data[i])) {\n                                        d.data[i] = {\n                                            count: d.data[i],\n                                            y: Math.max(d.data[i], minVal)\n                                        };\n                                    }\n                                }\n                            });\n                        } else if (type === 'pie') {\n                            Ext.each(data[0].data, function(point) {\n                                values.push(point[1]);\n                            });\n                            minVal = values.sort(function(a,b) {return a<b;})[0] * 0.025;\n                            for (var i=0; i<data[0].data.length; i++) {\n                                data[0].data[i] = {\n                                    name: data[0].data[i][0],\n                                    count: data[0].data[i][1],\n                                    y: Math.max(data[0].data[i][1], minVal)\n                                };\n                            }\n                        }\n                        return data;\n                    },\n                    height: (h || this.container.getHeight()) - 40, // leave some room for the header\n                    width: w || this.container.getWidth(),\n                    store: this.chartStore = new Ext.data.JsonStore({\n                        root: 'series',\n                        fields: [\n                            { name: 'name', type: 'string' },\n                            { name: 'data', type: 'object' },\n                            { name: 'interval', type: 'int' },\n                            { name: 'color', type: 'string', defaultValue: null }\n                        ],\n                        data: data\n                    }),\n                    chartConfig: cfg,\n                    loadMask: true,\n                    listeners: {\n                        'afterrender': function() {\n                            if (this.tile && this.tile.unsetFlatClickableStyle) {\n                                this.tile.unsetFlatClickableStyle();\n                                this.tile.removeClass('trending-tile');\n                                this.tile.setZoomEnabled(fa