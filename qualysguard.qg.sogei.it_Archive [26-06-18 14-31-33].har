roup by vulns logic\n                        var data = this.getData();\n                        if (['column', 'pie', 'table'].indexOf(data.chartType) >= 0 &&\n                                portal.asset.util.GroupByVulnsUtil.isVulnToken(value) &&\n                                !portal.asset.util.GroupByVulnsUtil.isValidVulnGroupQuery(data.query)) {\n                            return ['<i class=\"x-hide-display\" />']; // hack to mark as invalid but show no msg\n                        } else {\n                            return true;\n                        }\n                    }.createDelegate(this)\n                }),\n                this.columnsField = new portal.form.ComboBox({\n                    fieldLabel: $L('b3759f9a-6a0e-4d15-8eae-14128e10c080', 'Columns / Group By'),\n                    allowBlank: true,\n                    anchor: '-5',\n                    displayField: 'value',\n                    valueField: 'value',\n                    mode: 'local',\n                    hideRefreshLabel: true,\n                    refreshable: false,\n                    anyMatch: true,\n                    caseSensitive: false,\n                    typeAhead: false,\n                    bubbleEvents: ['selectionchange'],\n                    store: new Ext.data.ArrayStore({\n                        fields: ['value'],\n                        data: this.pivotTokens,\n                        expandData: true\n                    }),\n                    listeners: {\n                        select: this.onColumnsFieldValueChange,\n                        change: this.onColumnsFieldValueChange,\n                        specialkey: function(field, e){\n                            if (!field.isExpanded() && e.getKey() == e.ENTER) {\n                                this.onColumnsFieldValueChange(this.columnsField, this.columnsField.getValue());\n                                field.startValue = field.getValue();\n                            }\n                        },\n                        expand: function() {\n                           this.columnsField.layer.setWidth(this.columnsField.wrap.parent().getWidth());\n                        },\n                        scope: this\n                    }\n                }),\n                this.listColumnsField = new Qx.form.MultiSelectComboBox({\n                    fieldLabel: $L('e026b428-c06d-4db5-abdb-f544e113707a', 'Columns to display'),\n                    addAllSearchText: $L('db546384-5dd6-4e13-8bee-326f15b99660', 'Add all'),\n                    allowCommaInQuery: true,\n                    allowBlank: false,\n                    anchor: '-5',\n                    displayField: 'value',\n                    valueField: 'value',\n                    hideRefreshLabel: true,\n                    refreshable: false,\n                    mode: 'local',\n                    emptyText: $L('7460ab6b-3462-4f15-94d9-23d8e9bdbf22', 'Select columns'),\n                    enableCopyPaste: false,\n                    anyMatch: true,\n                    caseSensitive: false,\n                    value: [\"name\"],\n                    cacheSizes: false,\n                    store: new Ext.data.ArrayStore({\n                        fields: ['value'],\n                        data: this.listColumns,\n                        expandData: true,\n                        getTotalCount: function() {\n                            return this.listColumns.length || 0;\n                        }.createDelegate(this)\n                    }),\n                    listeners: {\n                        add: function(cmp, b, val) {\n                            cmp.store.remove(val);\n                        },\n                        selectionchange: function(cmp, value) {\n                            this.assetOrderField.store.loadData(value.filter(function(val) {\n                                return val !== \"address\" && val !== \"lastUserLoggedIn\" && val !== \"hostName\" && val !== \"tags\";\n                            }), false);\n                            if (value.indexOf(this.assetOrderField.getValue()) === -1) {\n                                if (value.length) {\n                                    var sortByFields = value.filter(function(val){\n                                        return val !== \"address\" && val !== \"lastUserLoggedIn\" && val !== \"hostName\" && val !== \"tags\";\n                                    });\n                                    sortByFields[0] ? this.assetOrderField.setValue(sortByFields[0]) : this.assetOrderField.clearValue();\n                                } else {\n                                    this.assetOrderField.clearValue();\n                                }\n                            }\n                            this.onColumnsFieldValueChange(this.columnsField, this.columnsField.getValue());\n                        },\n                        expand: function() {\n                            this.listColumnsField.layer.setWidth(this.listColumnsField.wrap.parent().getWidth());\n                        },\n                        show: {\n                            fn: function(cmp) {\n                                cmp.setWidth(cmp.outerWrap.getWidth() + 17); // hack to force proper layout\n                            },\n                            single: true,\n                            delay: 1\n                        },\n                        scope: this\n                    }\n                }),\n                this.assetOrderField = new portal.form.ComboBox({\n                    fieldLabel: $L('892f21d8-2f98-497d-a594-4c1e84d74988', 'Sort by'),\n                    allowBlank: true,\n                    anchor: '-5',\n                    displayField: 'value',\n                    valueField: 'value',\n                    mode: 'local',\n                    hideRefreshLabel: true,\n                    refreshable: false,\n                    anyMatch: true,\n                    value: 'name',\n                    store: new Ext.data.ArrayStore({\n                        fields: ['value'],\n                        expandData: true,\n                        data: ['name'],\n                        loadData: function(value) {\n                            // exclude unsortable address\", \"lastUserLoggedIn\", \"tags\" and \"hostName\"\n                            value.remove(\"tags\").remove(\"hostName\").remove(\"address\").remove(\"lastUserLoggedIn\");\n                            Ext.data.ArrayStore.prototype.loadData.call(this, value.sort());\n                        }\n                    }),\n                    listeners: {\n                        change: function() { this.fireEvent(\"valuechange\", this); },\n                        select: function() { this.fireEvent(\"valuechange\", this); },\n                        specialkey: function(field, e){\n                            if (!field.isExpanded() && e.getKey() == e.ENTER) {\n                                this.fireEvent(\"valuechange\", this);\n                                field.startValue = field.getValue();\n                            }\n                        },\n                        expand: function() {\n                           this.assetOrderField.layer.setWidth(this.assetOrderField.getWidth());\n                        },\n                        scope: this\n                    }\n                }),\n                this.sortField = new portal.form.ComboBox({\n                    fieldLabel: $L('892f21d8-2f98-497d-a594-4c1e84d74988', 'Sort by'),\n                    allowBlank: true,\n                    anchor: '-5',\n                    displayField: 'value',\n                    valueField: 'value',\n                    mode: 'local',\n                    hideRefreshLabel: true,\n                    refreshable: false,\n                    anyMatch: true,\n                    store: new Ext.data.ArrayStore({\n                        fields: ['value'],\n                        expandData: true,\n                        data: [\"count\"],\n                        loadData: function(value) {\n                            if (value.indexOf(\"count\") === -1) {\n                                value.push(\"count\");\n                            }\n                            Ext.data.ArrayStore.prototype.loadData.call(this, value.sort());\n                        }\n                    }),\n                    listeners: {\n                        change: function() { this.fireEvent(\"valuechange\", this); },\n                        select: function() { this.fireEvent(\"valuechange\", this); },\n                        specialkey: function(field, e){\n                            if (!field.isExpanded() && e.getKey() == e.ENTER) {\n                                this.fireEvent(\"valuechange\", this);\n                                field.startValue = field.getValue();\n                            }\n                        },\n                        expand: function() {\n                            this.sortField.layer.setWidth(this.sortField.getWidth());\n                        },\n                        scope: this\n                    }\n                }),\n                this.assetOrderDirField = new portal.form.ComboBox({\n                    fieldLabel: $L('2b0c3b8d-99fd-43a5-ac91-6eb57514cc3d', 'Sort direction'),\n                    allowBlank: false,\n                    anchor: '-5',\n                    displayField: 'name',\n                    valueField: 'value',\n                    mode: 'local',\n                    hideRefreshLabel: true,\n                    refreshable: false,\n                    value: 'ASC',\n                    store: new Ext.data.ArrayStore({\n                        fields: ['name', 'value'],\n                        data: [[ $L('27548d4b-a108-4aaa-a3c0-c656f6221964', 'Ascending'), 'ASC' ], [ $L('30bd63d0-cb3b-457e-bbba-d38efa14c46b', 'Descending'), 'DESC' ]]\n                    }),\n                    listeners: {\n                        change: function() { this.fireEvent(\"valuechange\", this); },\n                        select: function() { this.fireEvent(\"valuechange\", this); },\n                        specialkey: function(field, e){\n                            if (!field.isExpanded() && e.getKey() == e.ENTER) {\n                                this.fireEvent(\"valuechange\", this);\n                                field.startValue = field.getValue();\n                            }\n                        },\n                        expand: function() {\n                           this.assetOrderDirField.layer.setWidth(this.assetOrderDirField.getWidth());\n                        },\n                        scope: this\n                    }\n                }),\n                this.limitField = new portal.form.ComboBox({\n                    fieldLabel: $L('793d1e13-c076-4537-b2d5-7707fb44b1d7', 'Limit to'),\n                    allowBlank: false,\n                    anchor: '-5',\n                    displayField: 'name',\n                    valueField: 'value',\n                    mode: 'local',\n                    hideRefreshLabel: true,\n                    refreshable: false,\n                    store: new Ext.data.ArrayStore({\n                        fields: ['name', 'value'],\n                        data: []\n                    }),\n                    listeners: {\n                        change: function() { this.fireEvent(\"valuechange\", this); },\n                        select: function() { this.fireEvent(\"valuechange\", this); },\n                        specialkey: function(field, e){\n                            if (!field.isExpanded() && e.getKey() == e.ENTER) {\n                                this.fireEvent(\"valuechange\", this);\n                                field.startValue = field.getValue();\n                            }\n                        },\n                        expand: function() {\n                           this.limitField.layer.setWidth(this.limitField.getWidth());\n                        },\n                        scope: this\n                    }\n                }),\n                this.tokenFiltersLabel = new Ext.BoxComponent({\n                    html: \"<div class='section-subtitle'>\" + $L('4af8e4ff-724b-4db9-b430-205a9ce7dcc0', 'Filters') + \"</div>\"\n                }),\n                this.tokenFiltersNotice = new Ext.BoxComponent({\n                    html: [\n                        \"<div class='widget-filter-notice'>\",\n                            $L('c30d48ad-708f-42c3-a583-b25461748626', \"Add one or more filters to narrow down your results for the selected group.\"),\n                        \"</div>\"\n                    ].join(\"\")\n                }),\n                this.tokenFilters = new NS.form.GroupByFilterField({\n                    tokens: this.getGroupByFilterTokens(),\n                    listeners: {\n                        scope: this,\n                        change: function () {\n                            this.fireEvent(\"valuechange\", this);\n                        }\n                    }\n                }),\n                this.compareLabel = new Ext.BoxComponent({\n                    html: \"<div class='section-subtitle'>\" + $L('5ed62a3a-0587-4e61-ba72-84fc6a0b5797', \"Comparison\") + \"</div>\"\n                }),\n                this.compare = new Ext.form.Checkbox({\n                    hideLabel: true,\n                    boxLabel: $L('32246d36-3cee-41df-8d94-5852d2a33cc7', 'Compare with another reference query'),\n                    listeners: {\n                        scope: this,\n                        check: function() {\n                            if (this.compare.getValue()) {\n                                this.compareQueryField.show();\n                                this.compareQueryField.autoSize();\n                                this.query2TitleField.show();\n                                this.compareTypeField.show();\n                                this.compareTypeField.wrap.setWidth(this.compareTypeField.getWidth());\n                                this.compareQueryField.focus();\n                                this.fireEvent(\"valuechange\", this);\n                            } else {\n                                this.compareQueryField.hide();\n                                this.query2TitleField.hide();\n                                this.compareTypeField.hide();\n                                this.fireEvent(\"valuechange\", this, true);\n                            }\n                            this.doLayout();\n                        }\n                    }\n                }),\n                this.compareQueryField = this.getQueryField({\n                    tokens: this.searchTokens,\n                    listeners: {\n                        scope: this,\n                        render: function () { this.doLayout(); },\n                        expand: function (queryField) { queryField.onResize(); queryField.initPosAndSize(); },\n                        submit: function () { this.fireEvent(\"valuechange\", this); },\n                        resize: function () { this.doLayout(); }\n                    }\n                }),\n                this.query2TitleField = this.getTitleField({\n                    fieldLabel: $L('e0f6190a-cfc9-4b8e-865d-c8e19d79cb70', \"Comparison label\"),\n                    value: $L('a2878243-53d7-431a-8b27-5268b5b15c32', 'All Assets')\n                }),\n                this.compareTypeField = new portal.form.ComboBox({\n                    fieldLabel: $L('c08dfb83-17e7-478b-862f-2ee8c8103953', 'This set of assets represents '),\n                    allowBlank: false,\n                    anchor: '-5',\n                    displayField: 'name',\n                    valueField: 'value',\n                    mode: 'local',\n                    hideRefreshLabel: true,\n                    refreshable: false,\n                    value: \"superset\",\n                    store: new Ext.data.ArrayStore({\n                        fields: ['name', 'value'],\n                        data: [[$L('fd6282ab-3b1e-4fd8-bd4b-ff82d97d5ad1', 'A superset (contains all the assets from initial query)'), \"superset\"], [$L('3b9db35b-befb-4650-acff-bbe56e93d2fd', \"A subset (is contained within initial assets)\"), \"subset\"],  [$L('d6d318a5-5c50-4df1-9fa3-b35dabc7c9bd', \"A distinct set\"), \"distinct\"]]\n                    }),\n                    listeners: {\n                        change: function() { this.fireEvent(\"valuechange\", this); },\n                        select: function() { this.fireEvent(\"valuechange\", this); },\n                        specialkey: function(field, e){\n                            if (!field.isExpanded() && e.getKey() == e.ENTER) {\n                                this.fireEvent(\"valuechange\", this);\n                            }\n                        },\n                        scope: this\n                    }\n                }),\n                this.trendingLabel = new Ext.BoxComponent({\n                    html: \"<div class='section-subtitle'>\" + $L('c457fa44-80ad-4c4b-8c90-9186de86a852', \"Trending\") + \"</div>\"\n                }),\n                this.enableTrending = new Ext.form.Checkbox({\n                    hideLabel: true,\n                    boxLabel: $L('804b8f86-51ca-4132-928f-f30e5aa1bf5b', 'Collect trend data'),\n                    listeners: {\n                        scope: this,\n                        check: function () {\n                            if (this.enableTrending.getValue()) {\n                                this.trendingNotice.show();\n                                this.fireEvent(\"valuechange\", this, true);\n                            } else {\n                                this.trendingNotice.hide();\n                                this.fireEvent(\"valuechange\", this, true);\n                            }\n                            this.doLayout();\n                        }\n                    }\n                }),\n                this.trendingNotice = new Ext.BoxComponent({\n                    html: [\n                        \"<div class='widget-trending-notice'>\" + $L('0ea2b9d8-f950-4832-8b72-bd1cfb92f96c', \"This widget will store its results each day for up to <b>90 days</b>. The results will be plotted on a graph so that the data may be analyzed to identify trends.\") + \"</div>\",\n                        // \"<a href='#' class='widget-purge-data'>\", $L('90a3c7b2-0e4d-4f91-84a7-6171ff933f3f', \"Purge historical data\"), \"</a>\"\n                    ].join(\"\"),\n                    listeners: {\n                        'beforehide': function (box) {\n                            box.el.slideOut('t', {\n                                duration: 0.125, easing: 'ease-out ', callback: function () {\n                                    box.doHide();\n                                }\n                            });\n                            return false;\n                        },\n                        'show': function (box) {\n                            box.el.slideIn('t', {duration: 0.125, easing: 'ease-out '});\n                        },\n//                        'afterrender': function(box) {\n//                            box.el.on('click', this.onPurgeTrendingDataClick, this, { delegate: '.widget-purge-data', stopEvent: true });\n//                        }\n                        scope: this\n                    }\n                })\n            ]\n        }, cfg));\n\n        this.addEvents(\"valuechange\",\"validchange\");\n\n        this.on(\"afterrender\", function() {\n            new Ext.util.DelayedTask(this.init, this).delay(200);\n        }, this);\n    };\n\n    Ext.extend($cls, frame.mono.dialog.ObjectEditPanel, {\n        getQueryField: function(cfg) {\n            return new portal.form.search.LuceneSearchBox(Ext.apply({\n                plugins : {ptype: \"unescapingfield\"},\n                isFlatStyle: true,\n                displayHelp: true,\n                defaultHelpTpl: \"<h4>Enter the field name, then a colon, then your query.</h4>\" +\n                  \"<p><i>Examples</i></p>\" +\n                  \"<p>Find assets with open port <strong>80</strong></p>\" +\n                  \"<p><code>open.port: <strong>80</strong></code></p>\" +\n                  \"<p>Find assets used by the <strong>administrator</strong> user</p>\" +\n                  \"<p><code>accounts.username: <strong>administrator</strong></code></p>\",\n                i18n: {\n                    typeYourQuery: $L('e20f5bc8-0a20-4f54-b0bd-140579395b87', 'Type your query'),\n                    syntaxHelp: $L('975ceda8-b25b-4376-97a8-86dbf1871612', \"Syntax Help\"),\n                    viewMore: $L('bb8a2ff0-5129-4a81-9f07-95c0f8678dbc', \"view more\")\n                },\n                tokens: this.searchTokens,\n                listeners: {\n                    scope: this,\n                    blur: function() { this.fireEvent(\"valuechange\", this); },\n                    render: function () { this.doLayout(); },\n                    submit: function () { this.fireEvent(\"valuechange\", this); },\n                    resize: function () { this.doLayout(); },\n                    clickhelp: function() {\n                        if (this.searchHelpUrl) {\n                            var nameHelp = \"searchHelp\",\n                                infoHelp = 'status=no,height=' + 500 + ',width=' + 700 + ',resizable=yes,location=no,menubar=no,toolbar=no,scrollbars=yes',\n                                winHelp = window.open(this.searchHelpUrl, nameHelp, infoHelp);\n                            if (winHelp) {\n                                winHelp.focus();\n                            }\n                        }\n                    }\n                },\n                getKeyValues: function() {\n                    var o = this.getValue;\n                    this.getValue = Qx.form.search.LuceneSearchBox.prototype.getValue;\n                    var r = Qx.form.search.LuceneSearchBox.prototype.getKeyValues.call(this);\n                    this.getValue = o;\n                    return r;\n                },\n                selectOnHover: true,\n                fieldLabel: $L('fb27ff46-5146-4fd2-a9ce-a59315ab2279', 'Query'),\n                anchor: '-5'\n            }, cfg));\n        },\n        getTitleField: function(cfg) {\n            return new portal.core.form.TitleField(Ext.apply({\n                name: 'title',\n                allowBlank: true,\n                fieldLabel: $L('67303eb4-ed0a-4085-b324-9aed3f659c4b', 'Widget Title'),\n                emptyText: $L('65113d15-90f3-4fc1-b83b-7847efbc2b2c', 'Untitled Widget'),\n                anchor: '-5',\n                maxLength: 256,\n                enableKeyEvents: true,\n                validator: function(value) {\n                    if (!this.allowBlank && !value.trim().length) {\n                        return Ext.value(this.blankText, this.emptyText);\n                    }\n                    if (value.indexOf(\",\") !== -1) {\n                      return $L('99d48fc8-4645-4dbb-8c1e-40fa1fd8839b', \"The widget title cannot contain a comma.\");\n                    }\n                    return true;\n                },\n                listeners: {\n                    scope: this,\n                    keyup: function() {\n                        var isValid = this.getForm().isValid();\n                        this.fireEvent(\"validchange\", this, isValid);\n                    }\n                }\n            }, cfg));\n        },\n        showCompareFields: function(){\n          this.compareLabel.show();\n          this.compareQueryField.show();\n          this.query2TitleField.show();\n          this.compareTypeField.show();\n        },\n        init: function() {\n            this.limitField.getStore().loadData([[$L('3412475b-7aa5-417c-911c-b53d70f96512', 'TOP 50'), 50], [$L('20c81c1b-72ba-46c3-8375-21ec52283d23', \"TOP 25\"), 25],  [$L('c4c7eec8-53ed-411e-96ee-3135f685caa5', \"TOP 10\"), 10]]);\n\n            if (this.data && this.data.chartType) {\n                this.titleField.setValue(this.data.title);\n                this.queryField.setValue(this.data.query);\n                if (this.data.limit) {\n                    if (this.data.chartType === \"pie\" || this.data.chartType === \"column\" || this.data.chartType === \"threat\") {\n                        this.limitField.getStore().loadData([[$L('c4c7eec8-53ed-411e-96ee-3135f685caa5', 'TOP 10'), 10], [$L('1d8e35ab-c0ea-4533-aed2-a9068fab5c85', \"TOP 5\"), 5],  [$L('c48c10b5-d8c9-491f-88b1-17312dcad0e7', \"TOP 3\"), 3]]);\n                    }\n                    this.limitField.setValue(this.data.limit);\n                }\n                var idx = this.chartField.getStore().find('type', this.data.chartType);\n                this.chartField.select(idx, false, true);\n                this.onChartwidgetTypeselectionChange();\n                if (this.data.chartType === \"count\") {\n                    this.compare.setValue(this.data.compare);\n                    if (this.data.compare) {\n                        this.compareQueryField.setValue(this.data.query2);\n                        this.query2TitleField.setValue(Ext.util.Format.htmlEncode(this.data.query2Title));\n                        this.compareTypeField.setValue(Ext.util.Format.htmlEncode(this.data.compareType || \"distinct\"));\n                        this.showCompareFields();\n                    }\n                    if (this.enableDashboardTrending) {\n                        this.enableTrending.setValue(this.data.enableTrending);\n                        if (this.data.enableTrending) {\n                            this.trendingLabel.show();\n                            this.trendingNotice.show();\n                        }\n                    }\n                } else {\n                    var resultType = Ext.value(this.data.resultType, this.data.tile ? \"AGGREGATE\" : \"LIST\"); // existing widgets will default to \"AGGREGATE\", new to \"LIST\"\n                    this.resultTypeField.setValue(resultType);\n                    if (!Ext.isEmpty(this.data.categories)) {\n                        this.rowsField.setValue(this.data.categories);\n                        this.setColumnsFieldFilter();\n                    }\n                    if (!Ext.isEmpty(this.data.groupBy)) {\n                        var v = Ext.value(this.data.groupBy, \"\");\n                        this.columnsField.setValue(v.split(\",\")[0]);\n                    }\n                    if (this.data.chartType === \"table\" ) {\n                        this.sortField.store.loadData([this.rowsField.getValue(), this.columnsField.getValue(), \"count\"]);\n                    } else {\n                        this.sortField.store.loadData([this.rowsField.getValue(), \"count\"]);\n                    }\n                    if(this.data.chartType === \"column\" || this.data.chartType === \"pie\" || this.data.chartType === \"table\" && resultType === \"AGGREGATE\") {\n                        this.sortField.setValue(this.data.sort || \"count\");\n                        this.assetOrderDirField.setValue(this.data.sortAsc ? \"ASC\" : \"DESC\");\n                    }\n                    if (this.data.chartType === \"table\" && resultType === \"LIST\") {\n                        this.listColumnsField.setValue(this.data.categories ? this.data.categories.split(\",\") : [\"name\"]);\n                        this.assetOrderField.store.loadData(this.listColumnsField.getValue().remove(\"tags\"));\n                        this.assetOrderField.setValue(Ext.value(this.data.sort === \"hostName\" ? \"name\" : this.data.sort, \"name\")); // cannot sort by hostName, revert to sorting by name\n                        this.assetOrderDirField.setValue(this.data.sortAsc ? \"ASC\" : \"DESC\");\n\n                    } else {\n                        this.tokenFilters.setTokens(this.getGroupByFilterTokens());\n                        if (!Ext.isEmpty(this.data.groupByFilters)) {\n                            this.tokenFilters.setValue(this.data.groupByFilters, true);\n                        }\n                        if (!Ext.isEmpty(this.data.groupByFilterType)) {\n                            this.tokenFilters.setFilterType(this.data.groupByFilterType, true);\n                        }\n                    }\n                }\n            } else {\n                this.chartField.selectRange(0, 0);\n            }\n            if (!this.help) {\n                var url= (Passport?.isNewDocumentationEnable) ? `${Passport?.portalHelpBaseUrl}/${Passport?.getLanguage()?.toLowerCase()}/av/portal/${Passport?.portalVersion?.split(\"-\")[0]}/${'search_tips/search_ui.htm'}`\n                     : '/portal-help/' + Passport.getLanguage().toLowerCase() + '/assetview/search_tips/search_ui.htm';\n                fetch(url).then((response) => {\n                                      return response.text();\n                })\n                .then((html) => {\n                      if(html){\n                          this.help = document.createElement('div');\n                          this.help.innerHTML = resp.responseText;\n                          Ext.each([this.queryField, this.compareQueryField], function(sb) {\n                          Ext.each(Ext.query('div', this.help), function(el) {\n                              var token = el.className;\n                              if (sb.tokens[token]) {\n                                    sb.tokens[token].help = el.innerHTML;\n                              }\n                          }, this);\n                          sb.createTokens();\n                          }, this);\n                      }else{\n                           scope= this;\n                      }\n                }).catch(function(error) {\n                      scope= this;\n                  });\n            }\n        },\n        onChartwidgetTypeselectionChange: function(dv, selections) {\n            var chartType = this.chartField.getSelectedRecords()[0].data.type;\n            var limit = 0;\n            this.hideAllFormElements();\n            if (chartType === \"count\") {\n                this.compareLabel.show();\n                this.compare.show();\n                this.compare.setValue(this.compare.getValue());\n                if (this.compare.getValue()) {\n                  this.compareQueryField.setValue(this.compareQueryField.getValue());\n                  this.query2TitleField.setValue(this.query2TitleField.getValue());\n                  this.compareTypeField.setValue(this.compareTypeField.getValue() || \"distinct\");\n                  this.showCompareFields();\n                  this.compareQueryField.autoSize();\n                }\n                if (this.enableDashboardTrending) {\n                    this.trendingLabel.show();\n                    this.enableTrending.show();\n                    this.trendingNotice.show();\n                    this.enableTrending.setValue(this.data && this.data.enableTrending  || this.enableDashboardTrending || false);\n                }\n            } else if (chartType === \"table\") {\n                this.sortField.clearValue();\n                this.resultTypeField.show();\n                this.rowsField.show();\n                this.rowsField.setValue(Ext.isEmpty(this.rowsField.getValue()) ? \"tags.name\" : this.rowsField.getValue());\n                this.rowsField.label.update($L('d8a9dd33-d926-4a7e-9e93-c9a6f609208a', \"Rows\") + \" <span class='required'>*</span>\");\n                this.columnsField.show();\n                this.setColumnsFieldFilter();\n                this.limitField.show();\n                limit = Ext.isEmpty(this.limitField.getValue()) ? 50 : this.limitField.getValue();\n                if (limit < 10) {\n                    limit = 10;\n                }\n                this.limitField.getStore().loadData([[$L('3412475b-7aa5-417c-911c-b53d70f96512', 'TOP 50'), 50], [$L('20c81c1b-72ba-46c3-8375-21ec52283d23', \"TOP 25\"), 25],  [$L('c4c7eec8-53ed-411e-96ee-3135f685caa5', \"TOP 10\"), 10]]);\n                this.limitField.setValue(limit);\n                this.onResultTypeValueChange();\n                this.assetOrderDirField.setValue(\"ASC\");\n                this.sortField.store.loadData([this.rowsField.getValue(), this.columnsField.getValue(), \"count\"]);\n            } else if (chartType === \"column\" || chartType === \"pie\") {\n                this.rowsField.show();\n                this.rowsField.setValue(Ext.isEmpty(this.rowsField.getValue()) ? \"tags.name\" : this.rowsField.getValue());\n                this.rowsField.label.update($L('164ce1aa-2f1b-4372-bd6f-b7b76bd2bfcb', \"Categories\") + \" <span class='required'>*</span>\");\n                this.limitField.show();\n                this.sortField.setValue(\"count\");\n                limit = Ext.isEmpty(this.limitField.getValue()) ? 5 : this.limitField.getValue();\n                if (limit > 10) {\n                    limit = 10;\n                }\n                this.limitField.getStore().loadData([[$L('c4c7eec8-53ed-411e-96ee-3135f685caa5', 'TOP 10'), 10], [$L('1d8e35ab-c0ea-4533-aed2-a9068fab5c85', \"TOP 5\"), 5],  [$L('c48c10b5-d8c9-491f-88b1-17312dcad0e7', \"TOP 3\"), 3]]);\n                this.limitField.setValue(limit);\n                this.sortField.store.loadData([this.rowsField.getValue(), \"count\"]);\n                this.sortField.show();\n                this.assetOrderDirField.show();\n                this.assetOrderDirField.setValue(\"ASC\");\n                this.tokenFiltersLabel.show();\n                this.tokenFiltersNotice.show();\n                this.tokenFilters.show();\n                this.tokenFilters.setTokens(this.getGroupByFilterTokens());\n            }\n            this.doLayout();\n            this.fireEvent(\"valuechange\", this);\n        },\n        hideAllFormElements: function() {\n            this.resultTypeField.hide();\n            this.compareLabel.hide();\n            this.compare.hide();\n            this.compareQueryField.hide();\n            this.query2TitleField.hide();\n            this.compareTypeField.hide();\n            this.tokenFiltersLabel.hide();\n            this.tokenFiltersNotice.hide();\n            this.tokenFilters.hide();\n            this.trendingLabel.hide();\n            this.enableTrending.hide();\n            this.trendingNotice.doHide();\n            this.rowsField.hide();\n            this.columnsField.hide();\n            this.listColumnsField.hide();\n            this.assetOrderField.hide();\n            this.sortField.hide();\n            this.assetOrderDirField.hide();\n            this.limitField.hide();\n        },\n        isValid: function() {\n            return this.isValidQuery() && this.titleField.isValid() && this.isValidAssetList();\n        },\n        isValidGroupByVuln: function() {\n            return this.rowsField.isValid();\n        },\n        isValidAssetList: function() {\n            return this.getChartType() !== \"table\" || this.resultTypeField.getValue().inputValue !== \"LIST\" || this.listColumnsField.getValue().length > 0;\n        },\n        isValidQuery: function() {\n            var containsColon = /:/.test(this.queryField.getValue());\n            return this.isValidGroupByVuln() && this.tokenFilters.isValid() && this.queryField.isValid() && (containsColon ? this.queryField.getValue().split(\":\")[1].length > 0 : true);\n        },\n        getChartType: function() {\n            return this.chartField.getSelectedRecords().length > 0 ? this.chartField.getSelectedRecords()[0].data.type : (this.data && this.data.chartType ? this.data.chartType : \"count\");\n        },\n        getData: function() {\n            var chartType = this.getChartType();\n            var data = {\n                chartType: chartType,\n                title: this.titleField.getValue(),\n                query: this.queryField.getValue(),\n                groupBy: \"\",\n                categories: \"\",\n                limit: null,\n                compare: false\n            };\n            if (chartType === \"count\") {\n                data.compare = this.compare.getValue();\n                data.query2 = this.compareQueryField.getValue();\n                data.query2Title = this.query2TitleField.getValue();\n                data.compareType = this.compareTypeField.getValue();\n                data.enableTrending = this.enableDashboardTrending ? this.enableTrending.getValue() : this.data.enableTrending;\n                if (data.enableTrending) {\n                    data.trend1UUID = this.data.trend1UUID;\n                    if (data.compare) {\n                        data.trend2UUID = this.data.trend2UUID;\n                    }\n                }\n            } else {\n                if (chartType !== \"pie\" && chartType !== \"column\" && chartType !== \"map\") {\n                    data.groupBy = this.columnsField.getValue();\n                }\n                data.categories = this.rowsField.getValue();\n                data.limit = this.limitField.getValue();\n                if (portal.asset.util.GroupByVulnsUtil.isVulnToken(data.categories) &&\n                   (!data.groupBy || portal.asset.util.GroupByVulnsUtil.isVulnToken(data.groupBy)) &&\n                   portal.asset.util.GroupByVulnsUtil.isValidVulnGroupQuery(data.query)) {\n                    data.groupByQid = true;\n                }\n                if (chartType === \"table\") {\n                    data.resultType = this.resultTypeField.getValue().inputValue;\n             