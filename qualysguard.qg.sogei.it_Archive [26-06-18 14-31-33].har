SETS</div>\",\n                          \"<div class='numbers'>\"+portal.core.util.Renderers.friendlyNumber(data.prioritisedAssets)+\"</div>\",\n\n                      \"</div>\",\n                      \"<div class='chart-wrapper'>\",\n                        \"<div class='widget-text'>vs All Assets \"+portal.core.util.Renderers.friendlyNumber(data.totalAssets)+\"</div>\",\n                        \"<div class='widget-prioritization-chart'></div>\",\n                      \"</div>\",\n                  \"</div>\",\n                  \"<div class='container'>\",\n\n                  \"<div class='box'>\",\n                    \"<div class='widget-priotized'>PRIORITIZED VULNERABILITIES</div>\",\n                    \"<div class='numbers'>\"+portal.core.util.Renderers.friendlyNumber(data.prioritisedVuln)+\"</div>\",\n                  \"</div>\",\n                  \"<div class='chart-wrapper'>\",\n                      \"<div class='widget-text'>vs All Vulnerabilities \"+portal.core.util.Renderers.friendlyNumber(data.totalVuln)+\"</div>\",\n                      \"<div class='widget-vuln-chart'></div>\",\n                    \"</div>\",\n                  \"</div>\",\n                  \"<div class='container'>\",\n                      \"<div class='box'>\",\n                          \"<div class='widget-priotized'>AVAILABLE PATCHES</div>\",\n                          \"<div class='numbers'>\"+data.availablePatches+\"</div>\",\n                      \"</div>\",\n                  \"</div>\"\n              ],\n              listeners: {\n                  afterrender: function(box) {\n                      box.el.on('click', function(e) {\n                        var widgetName = Ext.util.Format.htmlEncode(this.tile.state.title);\n                        window.location = '/tp/#/live-report?dashboardUUID='+this.selectedDashboard.uuid+'&widgetName='+'\"' + (widgetName) + '\"';\n                      }, this);\n                      this.tile.setTitle(\"\");\n                      (function() {\n                          NS.PortletTrendChart.renderAssets(this.el, data);\n                          NS.PortletTrendChart.renderVulns(this.el, data);\n                      }).defer(10, this);\n                  },\n                  scope: this\n              }\n          }));\n        },\n\n        addCountChart: function(data, w, h) {\n            var diff = '', diffTs = '', prc = '';\n            var value = data.series[0].data[0] * 1;\n            var ref = data.series[0].data[1] * 1;\n            var color = \"#F5F5F5\";\n            if (this.compare) {\n                if (this.compareType === \"superset\") {\n                    diffTs = ref;\n                    prc = 100 - Math.ceil((ref - value) / ref * 10000) / 100;\n                } else if (this.compareType === \"subset\") {\n                    diffTs = ref;\n                    prc = Math.ceil((value - ref) / value * 10000) / 100;\n                } else {\n                    diff = value - ref;\n                    diffTs = $L('19667639-d396-41dd-93ea-bdf0749e369f', \"Difference \") + (diff >= 0 ? \"+\" : \"\") + diff;\n                    prc = Math.ceil(diff * 10000 / value) / 100;\n                }\n            }\n            prc = Ext.isNumber(+prc) ? (+prc).toFixed(2) : 0;\n            if (this.actions && this.actions.length > 0) {\n                var baseColActions = Qx.ArrayUtils.extract(this.actions, function(action) {\n                    return action.config.action === \"base\";\n                });\n                if (baseColActions.length === 1) {\n                    color = \"#\" + baseColActions[0].config.color;\n                }\n                Ext.each(this.actions, function(action) {\n                    var c = action.config;\n                    if (c.action == \"value\") {\n                        var col = \"#\" + c.color;\n                        var nb = Ext.isNumber(+c.value) ? +c.value : ref;\n                        var valueOperand = c.isPercentage ? parseFloat(prc) : value;\n                        if ((c.compare === \"lt\" && valueOperand < nb) ||\n                            (c.compare === \"eq\" && valueOperand === nb) ||\n                            (c.compare === \"gt\" && valueOperand > nb)) {\n                            color = col;\n                        }\n                    }\n                }, this);\n            }\n            var isDarkColor = Qx.ColorUtils.isDarkColor(color);\n            var textColor = isDarkColor ? \"#F4F4F4\" : \"#333333\";\n            var colorCls = isDarkColor ? 'portlet-single-point-dark' : 'portlet-single-point-light';\n            var title = Ext.isEmpty(this.title) ? $L('1d7d2d26-d927-4d6c-9bcf-0786ef2cb451',  \"assets\") : this.title;\n            var updateQuery2Title = function(title) {\n                return title === \"All Assets\" ? $L('474fd887-c52d-4340-9b6c-55153246d18d',  \"All Assets\") : Ext.util.Format.htmlEncode(title);\n            };\n            this.add(new Ext.BoxComponent({\n                cls: 'qx-center ' + colorCls + (this.enablePointClick ? ' portlet-single-point-clickable' : '') + (this.enableTrending ? ' portlet-trend' : ''),\n                style: \"backgroundColor: \" + color + \"; color: \" + textColor,\n                html: [\n                    (this.showTrends() ? \"\" : \"<div class='widget-inner-title'>\" + Ext.util.Format.htmlEncode(title) + \"</div>\"),\n                    \"<div class='qx-center-inner widget-inner-wrap'>\",\n                        \"<div class='cust-portlet-nb'>\", portal.core.util.Renderers.friendlyNumber(value), \"</div>\",\n                        (this.compare ?\n                            \"<div class='widget-compare'>\" +\n                                \"<div class='widget-compare-query-title'>\" + $L('9f695fd8-87c3-4e64-8056-ccd157a8fdae', \"vs\") + \"<strong>\" + updateQuery2Title(this.query2Title) + \"</strong></div>\" +\n                                \"<div class='widget-compare-query-change'>\" + diffTs + \"<strong>(\" + prc + \"%)</strong></div>\" +\n                            \"</div>\" :\n                        \"\"),\n                    (this.showTrends() ?\n                            \"<div class='widget-trend-ind'></div>\" :\n                        \"\"),\n                    \"</div>\",\n                    (this.showTrends() ? \"<div class='widget-trend-ct'></div>\" : \"\")\n                ].join(\"\"),\n                trendIndicatorTpl: new Ext.XTemplate(\n                    \"<div>\",\n                        \"<span class='widget-trend-ind-{[ values.trendPct >= 0 ? 'up' : 'down' ]}'></span>{[ values.trendPct.toFixed(1) ]}%\",\n                    \"</div>\",\n                    \"<div class='widget-trend-period'>\",\n                        $L('7f32a148-02b0-4240-822b-81c0ffdc341f', \"Showing last $1\", \"{[ Ext.util.Format.plural(values.trendPointCount, $L('9f8a8173-b6dd-4a0a-82b4-fe8d642d5676', 'day'), $L('5775c571-595c-46f8-bb99-2e08526d9f0b', 'days')) ]}\"),\n                        \"<tpl if=\\\"trendPointCount &gt; 1\\\"><span class='widget-trend-period-selector'></span></tpl>\",\n                    \"</div>\", {\n                    compiled: true\n                }),\n                updateTrendIndicator: function(data) {\n                    this.trendIndicatorData = Ext.apply(this.trendIndicatorData || {}, data);\n                    var content = this.trendIndicatorTpl.apply(this.trendIndicatorData);\n                    this.el.child('.widget-trend-ind').update(content);\n                },\n                listeners: {\n                    afterrender: function(box) {\n                        box.el.on('click', function(e) {\n                            if (e.getTarget('.widget-trend-period-selector')) {\n                                this.showTrendPeriodMenu(e, box);\n                                e.stopEvent();\n                            } else if (!this.showTrends() || e.getTarget('.cust-portlet-nb')) {\n                                this.firePointClickEvent();\n                            }\n                        }, this);\n                        if (this.tile && this.tile.setFlatClickableStyle) {\n                            this.tile.setFlatClickableStyle(box.el.getStyle(\"backgroundColor\"));\n                            if (!this.showTrends()) {\n                                this.tile.setTitle(\"\");\n                                this.tile.removeClass('trending-tile');\n                                this.tile.setZoomEnabled(false);\n                            } else {\n                                this.tile.setTitle(this.title);\n                                this.tile.addClass('trending-tile');\n                                this.tile.setZoomEnabled(true);\n                            }\n                        }\n                        if (this.showTrends()) {\n                             box.el.child('.cust-portlet-nb').hover(function() {\n                                if (box.trendChart) {\n                                    NS.PortletTrendChart.toggleSeriesActive(box.trendChart, 0, true);\n                                }\n                            }, function() {\n                                if (box.trendChart) {\n                                    NS.PortletTrendChart.toggleSeriesActive(box.trendChart, 0, false);\n                                }\n                            });\n                            if (this.compare) {\n                                box.el.child('.widget-compare').hover(function() {\n                                    if (box.trendChart) {\n                                        NS.PortletTrendChart.toggleSeriesActive(box.trendChart, 1, true);\n                                    }\n                                }, function() {\n                                    if (box.trendChart) {\n                                        NS.PortletTrendChart.toggleSeriesActive(box.trendChart, 1, false);\n                                    }\n                                });\n                            }\n                            var trendPct = 0\n                                hasTrendData = data.series[1] && data.series[1].points && data.series[1].points.length;\n                            if (hasTrendData) {\n                                // if today's date is the same as the latest trend value, be sure to base trend on the previous trend value\n                                var offset = 1;\n                                if (new Date().clearTime().getTime() === new Date(data.series[1].points[data.series[1].points.length - offset].name).clearTime().getTime()) {\n                                    offset = 2;\n                                }\n                                trendPct = this.getTrendPct(data.series[0].data[0], data.series[1].points[data.series[1].points.length - offset].value);\n                            }\n                            box.updateTrendIndicator({\n                                trendPct: trendPct,\n                                trendPointCount: (hasTrendData ? data.series[1].points.length : 0) + 1\n                            });\n                            (function() {\n                                if (NS.PortletTrendChart.isOnNewLine(this.el)) {\n                                    this.el.child('.widget-inner-wrap').removeClass('qx-center-inner');\n                                }\n                                box.trendChart = NS.PortletTrendChart.render(this.el, {\n                                    color: textColor,\n                                    series: data.series,\n                                    compare: this.compare,\n                                    title: this.title,\n                                    title2: this.query2Title\n                                });\n                            }).defer(10, this);\n                        }\n                    },\n                    resize: function(box) {\n                        if (box.trendChart) {\n                            if (NS.PortletTrendChart.isOnNewLine(this.el)) {\n                                this.el.child('.widget-inner-wrap').removeClass('qx-center-inner');\n                            } else {\n                                this.el.child('.widget-inner-wrap').addClass('qx-center-inner');\n                            }\n                            NS.PortletTrendChart.setSize(this.el, box.trendChart, this.compare);\n                        }\n                    },\n                    destroy: function(box) {\n                        if (box.trendChart) {\n                            box.trendChart.destroy();\n                        }\n                    },\n                    scope: this\n                }\n            }));\n        },\n\n        addTableChart: function(data, w, h) {\n            var cols = [];\n            if (this.resultType !== 'LIST') {\n                cols.push({\n                    header: $L('ae448ab4-c0ac-4444-b207-d03d1dcae5b0', 'Name'),\n                    dataIndex: 'name',\n                    id: 'name'\n                });\n            }\n            if (!data.categories) {\n                cols.push({\n                    header: $L('86b60a06-e732-419c-9750-8e602beddf76', 'Assets'),\n                    dataIndex: 'data'\n                });\n            } else {\n                Ext.each(data.categories, function(cat, idx) {\n                    if (this.resultType !== \"LIST\" || cat !== \"id\") { // hide ID column TODO: make ID field or hidden fields configurable?\n                        cols.push({\n                            header: this.tableColumnHeaderRenderer ? this.tableColumnHeaderRenderer(cat) : cat,\n                            sortable: false,\n                            dataIndex: 'data',\n                            tpl: new Ext.XTemplate(\n                                '{[ this.renderColumn(values.data[' + idx + '], \"' + cat + '\") ]}', {\n                                    renderColumn: function(v, name) {\n                                        if (!v || v === \"null\") return '<div class=\\\"empty-col-val\\\">'+$L('dfeff985-eb5e-4ed4-8e6d-45eb8008077c', \"Unknown\")+'</div>';\n                                        return this.resultType === \"LIST\" && this.listColumnRenderer && this.listColumnRenderer[Ext.util.Format.htmlEncode(name)] ? this.listColumnRenderer[Ext.util.Format.htmlEncode(name)](Ext.util.Format.htmlEncode(v)) : Ext.util.Format.htmlEncode(v);\n                                    }.createDelegate(this)\n                                }\n                            )\n                        });\n                    }\n                }, this);\n            }\n            this.add(new Qx.list.ListView({\n                cls: 'portlet-table-chart qx-list-view',\n                columns: cols,\n                store: new Ext.data.JsonStore({\n                    root: 'series',\n                    autoLoad: true,\n                    fields: ['name', 'data'],\n                    data: data\n                }),\n                listeners: {\n                    'afterrender': function(list) {\n                        if (this.sort) {\n                            // add sort indicator icon\n                            var idx = data.categories.indexOf(this.sort);\n                            if (idx >= 0) {\n                                list.innerHd.select('div').item(idx)\n                                    .addClass('qx-list-view-header-sortable')\n                                    .child('em').addClass(this.sortAsc ? 'sort-asc' : 'sort-desc');\n                            }\n                        }\n                        if (this.tile && this.tile.unsetFlatClickableStyle) {\n                            this.tile.unsetFlatClickableStyle();\n                            this.tile.removeClass('trending-tile');\n                            this.tile.setZoomEnabled(false);\n                        }\n                    },\n                    'click': function(list, idx, node, e) {\n                        var data = list.store.getAt(idx).data;\n                        data.col = Ext.query('dt em', node).indexOf(e.getTarget());\n                        data.colHeaders = this.data.categories;\n                        this.firePointClickEvent(data);\n                    },\n                    scope: this\n                }\n            }));\n        },\n\n        addColumnChart: function(data, w, h) {\n            var ordered = data.series;\n\n            // remove the Unknown values\n            if (!this.showEmpty) {\n                var empty = Qx.ArrayUtils.extract(ordered, function(o) {\n                    return o.name === \"Unknown\";\n                }, this);\n                ordered = Qx.ArrayUtils.subtract(ordered, empty);\n                if (ordered.length > this.limit) {\n                    ordered.pop();\n                }\n                if (ordered.length === 0) {\n                    this.showNoResultsText();\n                    return;\n                }\n            }\n            // align data\n            for (var i=0; i<ordered.length; i++) {\n                var val = Qx.ArrayUtils.clean(ordered[i].data)[0];\n                ordered[i].data = [];\n                for (var j=0; j<i; j++) {\n                    ordered[i].data[j] = null;\n                }\n                ordered[i].data[i] = val;\n            }\n            // rewrite categories\n            data.categories = Ext.pluck(ordered, \"name\");\n            data.series = ordered;\n\n            var self = this,\n                width = this.getWidth(),\n                height = this.getHeight(),\n                labelWidth = width / (data.categories.length * 1.2),\n                pointWidth = this.groupBy === '' ? labelWidth / 2.2 : width / (data.categories.length * data.series[0].data.length