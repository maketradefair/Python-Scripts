       in com.qualys.portal.application.module.dashboard.DashboardTileConfig!\n        this.query = cfg.query || '';\n        this.trend1UUID = cfg.trend1UUID;\n        this.chartType = cfg.chartType || portal.dashboard.Constants.chartType.labels.TIMELINE;\n        this.filters = cfg.filters || {};\n        this.categories = cfg.categories || '';\n        this.groupBy = cfg.groupBy || '';\n        this.groupByFilters = cfg.groupByFilters || {};\n        this.groupByFilterType = cfg.groupByFilterType || 'OR';\n        this.dashboardService = cfg.dashboardService;\n        this.legend = Ext.value(cfg.legend, false);\n        this.labels = Ext.value(cfg.labels, this.chartType === portal.dashboard.Constants.chartType.labels.COLUMN);\n        this.tableColumnHeaderRenderer = cfg.tableColumnHeaderRenderer || false;\n        this.listColumnRenderer = cfg.listColumnRenderer || false;\n        this.enablePointClick = cfg.enablePointClick !== false;\n        this.query2 = cfg.query2 || '';\n        this.trend2UUID = cfg.trend2UUID;\n        this.compare = cfg.compare === true;\n        this.compareType = cfg.compareType || 'superset';\n        this.query2Title = cfg.query2Title || '';\n        this.enableTrending = cfg.enableTrending === true;\n        this.actions = cfg.actions || [];\n        this.donut = cfg.donut !== false;\n        this.vertical = cfg.vertical !== false;\n        this.resultType = cfg.resultType;\n        this.sort = cfg.sort;\n        this.sortAsc = cfg.sortAsc;\n        this.reportConfig= cfg.tile && cfg.tile.state;\n        this.selectedDashboard = cfg.selectedDashboard;\n\n        /**\n         * @property resultCount\n         * The total count of items returned in the dataset. Read-only.\n         */\n        this.resultCount = 0;\n\n        /**\n         * @property resultCount2\n         * The total count of items returned in the dataset for the secondary query. Read-only.\n         */\n        this.resultCount2 = 0;\n\n        $cls.superclass.constructor.call(this, Ext.apply({\n            layout: 'fit',\n            flex: 1\n        }, cfg));\n\n        /**\n         * thrown in case of syntax error\n         */\n        this.addEvents('failure', 'success', 'load');\n    };\n\n    Ext.extend($cls, Ext.Container, {\n        afterRender: function() {\n            $cls.superclass.afterRender.apply(this, arguments);\n\n            if (this.tile) {\n                if ((this.chartType === 'threat' || this.chartType==='prioritization') && this.tile.actions && this.tile.actions.length > 0) {\n\n                    // hide the \"configure\" menu item since no config options are available for threat feeds\n                    var configure = this.tile.getActionMenuItem($L('7dd897c5-c981-476b-8379-8f7886b90f65', 'Configure Widget'));\n                    if (configure) {\n                        configure.disable();\n                    }\n                    // hide the \"export\" menu item\n                    var exportWidget = this.tile.getActionMenuItem($L('49ce935b-f13a-422b-a4f6-2d73da35f694', 'Export this Widget'));\n                    if (exportWidget) {\n                        exportWidget.disable();\n                    }\n                    // hide the \"create\" menu item\n                    var create = this.tile.getActionMenuItem($L('fa2bbfb4-e49b-45bf-a757-3b732da0134e', 'Create Template from this Widget'));\n                    if (create) {\n                        create.disable();\n                    }\n                }\n            }\n        },\n\n        onResize: function() {\n            $cls.superclass.onResize.apply(this, arguments);\n\n            if (this.getEl().isMasked()) {\n                this.showLoadMask(); // recenters mask\n            }\n        },\n\n        showLoadMask: function() {\n            this.getEl().mask($L('216d0bf3-475d-4e12-9578-b96d8b73388a', 'Loading...'));\n        },\n        getTagsArr: function(data) {\n          var tags = [];\n          Object.keys(data).forEach(function(key) {\n            tags.push({\n              name: data[key].label,\n              id: data[key].id\n            });\n          });\n          return tags;\n        },\n        getAgeFilterValues: function(ageObj) {\n          if (!ageObj) {\n            return null;\n          }\n          let values = [];\n          for (let key in ageObj) {\n            if (ageObj[key]) {\n              values.push(key);\n            }\n          }\n          return values;\n        },\n        buildRtiQuery: function(rtiSelection) {\n          var rtiQuery= [];\n          if (rtiSelection && rtiSelection.length>0) {\n            for (let i = 0;i < rtiSelection.length; i++) {\n              rtiQuery.push(\"vulnerabilities.vulnerability.threatIntel.\"+rtiSelection[i]+\":True\");\n            }\n          }\n          return rtiQuery;\n        },\n        /**\n         * Reload data from service call\n         */\n        reload: function(preventReload, invalidateCache, callback) {\n            if (!this.rendered) {\n                this.on('afterrender', this.reload, this, 'single');\n                return;\n            }\n            if (preventReload && this.data) {\n                this.refreshChart(this.data);\n                if (typeof callback !== 'undefined') {\n                    callback();\n                }\n            } else {\n                var cfg = this.getConfig();\n                this.showLoadMask();\n                if (this.chartType === \"prioritization\") {\n                  this.prioritizationData = this.havingQuery && JSON.parse(this.havingQuery);\n                  Ext.Ajax.request({\n                      url: '/tp/rest/1.0/prioritizationReport/count',\n                      method: 'POST',\n                      jsonData: {\n                          'defaultFilter': \"vulnerabilities.typeDetected:[Confirmed, Potential] and vulnerabilities.found:TRUE and vulnerabilities.disabled:FALSE and vulnerabilities.ignored:FALSE\",\n                          'rti': this.prioritizationData && this.buildRtiQuery(this.prioritizationData.rti),\n                          'tags': this.prioritizationData && this.getTagsArr(this.prioritizationData.tags),\n                          'vulnAge': this.prioritizationData && this.getAgeFilterValues(this.prioritizationData.vulnAge),\n                          'attackSurface': this.prioritizationData && this.prioritizationData.attackSurface\n                      },\n                      success: function(data) {\n                        this.doLayout();\n                        this.getEl().unmask();\n                        this.refreshChart(data);\n                      },\n                      failure: function(err, msg) {\n                        this.getEl().unmask();\n                        this.showFailure(msg);\n                      },\n                      scope: this\n                  });\n\n                }else {\n                  this.dashboardService.preview.call(this, Ext.apply({ refreshCache: !!invalidateCache }, cfg), {\n                      success: function(data) {\n                          this.resultCount = data.resultCount;\n                          this.resultCount2 = data.resultCount2;\n                          this.data = data;\n                          this.getEl().unmask();\n                          this.refreshChart(data);\n                          if (typeof callback !== 'undefined') {\n                              callback(data, cfg);\n                          }\n                          this.fireEvent('load', this, data);\n                      },\n                      failure: function(err, msg) {\n                          this.totalCount = this.totalCount2 = 0;\n                          this.showFailure(msg);\n                      },\n                      scope: this\n                  });\n                }\n            }\n        },\n\n        test: function(listeners) {\n            this.getEl().mask($L('c4910318-832b-4f68-8758-fcc68ad1eb32', 'Please wait...'));\n            this.dashboardService.preview.call(this, this.getConfig(), Ext.apply({\n                success: function() {\n                    this.doLayout();\n                    this.getEl().unmask();\n                    this.fireEvent('success', this);\n                },\n                failure: function(err, msg) {\n                    this.showFailure(msg);\n                    this.fireEvent('failure', this);\n                },\n                scope: this\n            }, listeners || {}));\n        },\n\n        showFailure: function(msg) {\n            this.getEl().unmask();\n            this.removeAll();\n            var errorMessage = $L('a9145bca-a3b5-4641-b44a-3359c4678559', 'Your query has a syntax error. Please fix it and try again.');\n            if (msg && msg.exception && msg.exception.message && (msg.exception.className ===\"QqlParseException\" || msg.exception.className === \"ExposedRuntimeException\")) {\n                errorMessage = $L('8fde40f2-0f55-4c6a-8a1c-a85df1afb577', msg.exception.message);\n            } else if (msg && msg.exception && msg.exception.className === \"QqlException\") {\n                errorMessage = $L('0a132090-fd1b-4295-950b-18d5086a25c0', 'An error occurred while executing query. Please try again.');\n            } else if (msg && msg.exception && msg.exception.message && msg.exception.className ===\"ServiceExpiredException\") {\n                errorMessage = $L('ff23d1b4-9e6e-4c11-bc42-43904891e6d7', \"This widget requires an active subscription to Threat Protection\");\n            }\n\n            this.add(new Ext.BoxComponent({\n                html: Qx.DomUtils.center('<div class=\"api-error\">' + errorMessage + '</div>')\n            }));\n\n            this.doLayout();\n        },\n\n        refresh: function(w, h) {\n            if (Ext.isDefined(this.data)) {\n                this.refreshChart(this.data, w, h);\n            }\n        },\n        getConfig: function() {\n            var data = {\n                chartType: this.chartType,\n                query: this.query.replace(/&lt;/g,\"<\").replace(/&gt;/g,\">\"),\n                categories: this.categories,\n                groupBy: this.groupBy,\n                groupByFilters: this.groupByFilters,\n                groupByFilterType: this.groupByFilterType,\n                filters: this.filters,\n                legend: this.legend,\n                limit: this.limit,\n                showEmpty: this.showEmpty,\n                query2: this.query2.replace(/&lt;/g,\"<\").replace(/&gt;/g,\">\"),\n                compare: this.compare,\n                compareType: this.compareType,\n                query2Title: this.query2Title,\n                enableTrending: this.showTrends(),\n                actions: this.actions,\n                vertical: this.vertical,\n                donut: this.donut,\n                havingQuery: this.reportConfig && this.reportConfig.havingQuery\n            };\n            if (this.enableTrending) {\n                if (this.trend1UUID) {\n                    data.trend1UUID = this.trend1UUID;\n                }\n                if (this.compare && this.trend2UUID) {\n                    data.trend2UUID = this.trend2UUID;\n                }\n            }\n            if (data.chart !== 'timeline') {\n                data.xAxis = this.xAxis;\n                data.yAxis = this.yAxis;\n            }\n            if (data.chartType === 'table') {\n                data.resultType = this.resultType;\n                data.sort = this.sort;\n                data.sortAsc = this.sortAsc\n                if (this.resultType === \"LIST\") {\n                    // append ID field\n                    data.categories += \",id\";\n                }\n            }\n            if (data.chartType == \"column\" || data.chartType == \"pie\") {\n                data.sortAsc = this.sortAsc;\n                data.sort = this.sort;\n            }\n            if (portal.asset.util.GroupByVulnsUtil.isVulnToken(data.categories) &&\n                   (!data.groupBy || portal.asset.util.GroupByVulnsUtil.isVulnToken(data.groupBy)) &&\n                   portal.asset.util.GroupByVulnsUtil.isValidVulnGroupQuery(data.query)) {\n                data.groupByQid = true;\n            }\n            return data;\n        },\n\n        setConfig: function(config) {\n            Ext.apply(this, config);\n            var iconCls = config.chartType;\n            if (iconCls === 'timeline') {\n                iconCls = 'line';\n            }\n            this.titleIconCls = 'qx-icon-graph-small qx-icon-graph-' + iconCls;\n        },\n\n\n        /**\n         * Redraw the chart\n         */\n        refreshChart: function(data, w, h) {\n            if (data !== null) {\n                this.removeAll();\n                if (Ext.isArray(data.series) && data.series.length === 0) {\n                    this.showNoResultsText();\n                } else {\n                    switch (this.chartType) {\n                        case portal.dashboard.Constants.chartType.labels.TIMELINE:\n                            this.addTimelineChart(data, w, h);\n                            break;\n                        case portal.dashboard.Constants.chartType.labels.COUNT:\n                            this.addCountChart(data, w, h);\n                            break;\n                        case portal.dashboard.Constants.chartType.labels.TABLE:\n                            this.addTableChart(data, w, h);\n                            break;\n                        case portal.dashboard.Constants.chartType.labels.COLUMN:\n                            this.addColumnChart(data, w, h);\n                            break;\n                        case portal.dashboard.Constants.chartType.labels.PIE:\n                            this.addPieChart(data, w, h);\n                            break;\n//                        case portal.dashboard.Constants.chartType.labels.MAP:\n//                            this.addMapChart(data, w, h);\n//                            break;\n                        case portal.dashboard.Constants.chartType.labels.THREAT:\n                            this.addThreatFeed(data, w, h);\n                            break;\n                        case portal.dashboard.Constants.chartType.labels.PRIORTIZATION:\n                            this.addPriotizationReportChart(data, w, h);\n                            break;\n                    }\n                }\n                this.fireEvent(\"success\", this);\n                this.doLayout();\n            } else {\n                this.fireEvent(\"failure\", this);\n            }\n        },\n\n        getMaxSeriesData: function(data) {\n            var max = 0;\n            if (data.series) {\n                Ext.each(data.series, function(serie) {\n                    if (serie.data) {\n                        Ext.each(serie.data, function(d) {\n                            if (d > max) {\n                                max = d;\n                            }\n                        });\n                    }\n                });\n            }\n            return max;\n        },\n\n        /**\n         * Create the timeline chart\n         */\n        addTimelineChart: function(data, w, h) {\n            var interval = data.series[0].interval;\n            var self = this;\n            var max = this.getMaxSeriesData(data);\n\n            this.addChart(Qx.chart.Highchart.Configs.get('area', {\n                plotOptions: {\n                    series: {\n                        pointInterval: interval,\n                        pointStart: this.getUTCdate(data.startDate),\n                        cursor: this.enablePointClick ? 'pointer' : 'default'\n                    },\n                    area: {\n                        point: {\n                            events: {\n                                click: