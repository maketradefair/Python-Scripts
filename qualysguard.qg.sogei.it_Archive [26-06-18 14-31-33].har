9fd7-c4a82a8b113e', 'Count')]);\n        }\n        if (Ext.value(this.widgetCfg.table, true)) {\n            chartwidgetTypes.push(['table', 'qx-icon-graph-table', $L('b6330273-b8d1-422e-afca-c5a71bfcaa40', 'Table')]);\n        }\n        if (Ext.value(this.widgetCfg.column, true)) {\n            chartwidgetTypes.push(['column', 'qx-icon-graph-column', $L('377c581f-a818-4653-8b45-bb02316daa80', 'Bars')]);\n        }\n        if (Ext.value(this.widgetCfg.pie, true)) {\n            chartwidgetTypes.push(['pie', 'qx-icon-graph-pie', $L('ffc5cd73-fdcf-4a72-8035-f80beefb2b85', 'Pie')]);\n        }\n        if (Ext.value(this.widgetCfg.map, true)) {\n            chartwidgetTypes.push(['map', 'qx-icon-graph-map', $L('2a1a4b84-d3c5-46b9-b6fb-89cddbe56787', 'Map')]);\n        }\n\n        $cls.superclass.constructor.call(this, Ext.apply({\n            items: [\n                this.section({\n                    title: $L('cbb22feb-15fb-464d-af6d-ab5fb7afcd95', \"Select data for your widget using the form below\")\n                }),\n                this.chartField = new Ext.DataView({\n                    cls: 'dv-btn-chart-type',\n                    store: new Ext.data.ArrayStore({\n                        autoLoad: true,\n                        fields: ['type', 'cls', 'title'],\n                        data: chartwidgetTypes\n                    }),\n                    singleSelect: true,\n                    itemSelector: '.btn-chart-type',\n                    tpl: new Ext.XTemplate(\n                        '<tpl for=\".\">',\n                        '<div class=\"btn-chart-type\">',\n                        '<tpl if=\"type===\\'count\\'\">',\n                        '<span class=\"qx-icon-graph btn-chart-type-count\">01</span>',\n                        '</tpl>',\n                        '<tpl if=\"type!==\\'count\\'\">',\n                        '<span class=\"qx-icon-graph {cls}\"></span>',\n                        '</tpl>',\n                        '<div clas