ng.format(tooltipTpl, $L('b69a2e83-b6eb-4028-90f4-e8f7b69255c3', 'Count'), count));\n                mapData.push({\n                    latitude: mockLocation[0], // s.data[s.data.length - 4],\n                    longitude: mockLocation[1], // s.data[s.data.length - 3],\n                    z: count,\n                    tooltip: mockLocation[2] + '<br>' + tooltip.join('<br>'),\n                    rawData: s\n                });\n            }, this);\n            var map = Ext.create({\n                xtype: 'qxhighmap',\n                height: h,\n                width: w,\n                mapData: Highcharts.maps['custom/world'],\n                chartConfig: Qx.chart.Highchart.Configs.get('map', {\n                    chart: {\n                        backgroundColor: '#a3ccff',\n                        spacing: [0, 0, 15, 0]\n                    },\n                    title: {\n                        enabled: false\n                    },\n                    mapNavigation: {\n                        enabled: true,\n                        enableMouseWheelZoom: false,\n                        buttonOptions: {\n                            alignTo: 'spacingBox'\n                        }\n                    },\n                    series: [{\n                        name: 'Countries',\n                        showInLegend: false,\n                        nullColor: '#c0e0bb',\n                        borderColor: '#757575',\n                        color: '#c0e0bb',\n                        enableMouseTracking: false,\n                    }, {\n                        type: 'mapbubble',\n                        dataLabels: {\n                            enabled: this.labels,\n                            style: {\n                                color: \"#F5F5F5\",\n                                fontFamily: 'helvetica,arial,sans-serif'\n                            }\n                        },\n                        name: '',\n                        cursor: 'pointer',\n                        marker: {\n                            fillOpacity: 0.7\n                        },\n                        maxSize: 12,\n                        minSize: 3,\n//                        zMax: 20,\n//                        zMin: 8,\n                        events: {\n                            click: function (e) {\n                                console.log(e.point);\n                                // this.firePointClickEvent(rec.data.rawData);\n                            }.createDelegate(this)\n                        }\n                    }]\n                }),\n                enableTooltip: true,\n                showLegend: this.legend,\n                store: this.store = new Ext.data.JsonStore({\n                    fields: [{\n                        name: 'lat',\n                        mapping: 'latitude',\n                        type: 'float'\n                    }, {\n                        name: 'lon',\n                        mapping: 'longitude',\n                        type: 'float'\n                    }, {\n                        name: 'z',\n                        type: 'int'\n                    }, {\n                        name: 'tooltip',\n                        type: 'string'\n                    }],\n                    data: mapData\n                }),\n                setSeriesData: function(series, data) {\n                    series[1].data = data;\n                },\n                getTooltipConfig: function() {\n                    return {\n                        useHTML: true,\n                        formatter: function() {\n                            return this.point.tooltip;\n                        },\n                        style: {\n                            fontFamily: 'helvetica,arial,sans-serif'\n                        }\n                    };\n                },\n                listeners: {\n                    'afterrender': function() {\n                        if (this.tile && this.tile.unsetFlatClickableStyle) {\n                            this.tile.unsetFlatClickableStyle();\n                            this.tile.removeClass('trending-tile');\n                            this.tile.setZoomEnabled(false);\n                        }\n                    },\n                    scope: this\n                }\n            });\n\n            this.add(map);\n        },\n\n        addThreatFeed: function (data, w, h) {\n            var formattedData = [];\n            Ext.each(data.series, function(series) {\n                formattedData.push({\n                    title: series.data[0].parsedContent.title,\n                    severity: series.data[0].severity,\n                    qids: series.data[0].qids,\n                    assetCount: series.data[1],\n                    publishDate: series.data[0].publishDate,\n                    esQuery: series.data[0].esQuery,\n                    isNew: series.data[0].isNew\n                });\n            });\n            this.add(Ext.create({\n                xtype: 'qxlistview',\n                height: h,\n                width: w,\n                columns: [{\n                    header: $L('f4495a8d-0bc9-437f-bd5e-2a4312e4c77f', 'Title'),\n                    width: 0.55,\n                    sortable: false,\n                    dataIndex: 'title',\n                    tpl: new Ext.XTemplate(\n                        '<div class=\"portlet-threat-feed-title\">{[ this.getNewLabel(values) ]}{title}</div>', {\n                        getNewLabel: function(values) {\n                            if (values.isNew) {\n                                return '<span class=\"portlet-threat-feed-new\">' + $L('32df519b-dbf9-4000-94a4-8f2dc6da104c', 'New') + '</span>';\n                            }\n                            return '';\n                        }\n                    })\n                }, {\n                    header: $L('1912ecc6-6e8a-4c6c-8965-89ef8c965bf8', 'Impacted Assets'),\n                    align: 'center',\n                    width: 0.15,\n                    dataIndex: 'assetCount',\n                    sortable: false,\n                    cls: 'portlet-threat-feed-assessment',\n                    tpl: new Ext.XTemplate(\n                        '<span class=\"portlet-threat-feed-asset-count\">{[this.getAssetCount(values)]}</span>',\n                        {\n                            getAssetCount: function(values) {\n                                if (Ext.isEmpty(values.esQuery) && Ext.isEmpty(values.qids)) {\n                                    return $L('9cd25ef2-724e-4a90-81b9-90d88db0523f', \"N/A\");\n                                }\n                                return '<span ext:qtip=\"' + portal.asset.v2.shared.Renderer.getShortNb(values.assetCount) + ' assets\">' + portal.core.util.Renderers.friendlyNumber(values.assetCount) + \"</span>\";\n                            }\n                        }\n                    )\n                }, {\n                    header: $L('584052a2-8a7b-44bf-ab0e-74a11164e9e6', 'Severity'),\n                    align: 'center',\n                    width: 0.15,\n                    dataIndex: 'severity',\n                    sortable: false,\n                    cls: 'portlet-threat-feed-severity',\n                    tpl: [\n                        '<span class=\"qx-icon-severity qx-icon-severity-{[ values.severity ? values.severity.toLowerCase() : \"none\" ]}\"></span>'\n                    ].join('')\n                }, {\n                    header: $L('824cf14a-d215-4c3f-bad3-2562bda758f0', 'Published'),\n                    width: 0.15,\n                    sortable: false,\n                    cls: 'portlet-threat-feed-publish-date',\n                    dataIndex: 'publishDate',\n                    tpl: new Ext.XTemplate(\n                        '{[this.getPublishDate(values.publishDate)]}', {\n                        getPublishDate: function(date) {\n                            var d = portal.core.util.Renderers.date.toUserTZ(date);\n                            return Qx.DateUtils.FriendlyDateTime.format(d, Qx.DateUtils.patterns.ShortDate);\n                        }\n                    })\n                }],\n                store: new Ext.data.JsonStore({\n                    fields: [\n                        { name: 'title' },\n                        { name: 'severity' },\n                        { name: 'esQuery' },\n                        { name: 'qids' },\n                        { name: 'publishDate', type: 'date', convert: function(d) {\n                            // dates coming from the AV cache could be numbers, not actual Date instances\n                            return d instanceof Date ? d : new Date(d);\n                        } },\n                        { name: 'assetCount', type: 'int' }\n                    ],\n                    data: formattedData\n                }),\n                listeners: {\n                    afterrender: function(cmp) {\n                        cmp.el.on('click', function(e) {\n                            var rec = cmp.getRecord(e.getTarget('.x-list-row'));\n                            var query = portal.asset.v2.shared.Renderer.getEsQuery(rec);\n                            if (!Ext.isEmpty(query)) {\n                                this.firePointClickEvent(query);\n                            }\n                        }, this, { delegate: '.portlet-threat-feed-asset-count' });\n\n                        if (this.tile && this.tile.unsetFlatClickableStyle) {\n                            this.tile.unsetFlatClickableStyle();\n                            this.tile.removeClass('trending-tile');\n                            this.tile.setZoomEnabled(false);\n                        }\n                    },\n                    scope: this\n                }\n            }));\n        },\n\n        setFilters: function(filters, invalidateCache) {\n            this.filters = filters || {};\n            this.reload(false, invalidateCache);\n        },\n\n        getUTCdate: function(date){\n            var startDate = portal.core.util.Renderers.date.toUserTZ(date);\n            return Date.UTC(startDate.getUTCFullYear(), startDate.getUTCMonth(), startDate.getUTCDate(), startDate.getUTCHours(), startDate.getUTCMinutes());\n        },\n\n        getDateFormatter: function(){\n            return function() {\n                var date = new Date(this.value);\n                return [portal.core.util.Renderers.date.shortDate(date), portal.core.util.Renderers.date.time(date)].join('<br/>');\n            };\n        },\n\n        firePointClickEvent: function(data) {\n            if (this.enablePointClick) {\n                // Table charts pass row data, threat charts pass an ES query, and other charts pass the clicked\n                // Hichcharts.Point object.\n                // This data will be normalized into an object representing the item that was clicked,\n                // where the keys are the field name(s) and the values are the field value(s).\n                var clicked = {};\n                var fields = [this.categories, this.groupBy].join(',').split(',');\n                if (this.chartType === portal.dashboard.Constants.chartType.labels.TABLE || this.chartType === portal.dashboard.Constants.chartType.labels.COUNT || this.chartType === portal.dashboard.Constants.chartType.labels.MAP) {\n                    // get row data\n                    Ext.each(fields, function(fld, idx) {\n                        if (fld) {\n                            if (idx === 0) {\n                                clicked[fld] = data.name;\n                            } else {\n                                clicked[fld] = data.data[idx - 1];\n                            }\n                        }\n                    });\n                    if (this.chartType === portal.dashboard.Constants.chartType.labels.TABLE) {\n                        clicked.col = data.col;\n                        clicked.colHeaders = data.colHeaders;\n                        if (this.resultType === \"LIST\") {\n                            clicked.id = data.data[data.colHeaders.indexOf(\"id\")]; // TODO: make ID field configurable?\n                        }\n                    }\n                } else if (this.chartType === portal.dashboard.Constants.chartType.labels.TIMELINE) {\n                    clicked.start = data.x;\n                    clicked.end = data.x + data.series.pointInterval;\n                    if (!Ext.isEmpty(this.categories)) {\n                        clicked[this.categories] = data.series.name;\n                    }\n                } else if (this.chartType === portal.dashboard.Constants.chartType.labels.THREAT) {\n                    this.query = data;\n                } else {\n                    // determine clicked data from Point object\n                    // Note: this assumed that grouped series have names containing all fields (separated by semi-colon)\n                    var pointValues = data.name ? [ data.name ] : data.series.name.split(';');\n                    if (data.category) { // column charts should have the category field\n                        pointValues.unshift(data.category);\n                    } else if (this.chartType !== portal.dashboard.Constants.chartType.labels.PIE && this.groupBy !== \"\") { // pie will alwalys have a category but no groupBy\n                        fields.shift(); // no category, remove from fields list\n                    }\n                    Ext.each(fields, function(fld, idx) {\n                        if (fld) {\n                            clicked[fld] = pointValues[idx];\n                        }\n                    });\n                }\n                Ext.iterate(clicked, function(fld, value) {\n                    if (fld === \"vulnerabilities.vulnerability.title\") {\n                        // AV-876: vuln titles are stored as QID-<qid> <title>, so we cannot use backticks to delimit, have to perform fuzzy match (quoted value)\n                        clicked[fld] = { value: value.replace(/\"/g, ''), type: \"quoted\" };\n                    }\n                });\n                this.fireEvent('pointclick', this, this.getConfig().query, clicked);\n            }\n        },\n\n        fireLegendClickEvent: function(data) {\n            if (this.enablePointClick === true) {\n                // Table charts pass row data, other charts pass the clicked Hichcharts.Point object.\n                // This data will be normalized into an object representing the item that was clicked,\n                // where the keys are the field name(s) and the values are the field value(s).\n                var clicked = {};\n                var fields = [this.categories, this.groupBy].join(',').split(',');\n                if (this.chartType === portal.dashboard.Constants.chartType.labels.TABLE || this.chartType === portal.dashboard.Constants.chartType.labels.COUNT|| this.chartType === portal.dashboard.Constants.chartType.labels.MAP) {\n                    // get row data\n                    Ext.each(fields, function(fld, idx) {\n                        if (fld) {\n                            if (idx === 0) {\n                                clicked[fld] = data.name;\n                            } else {\n                                clicked[fld] = data.data[idx - 1];\n                            }\n                        }\n                    });\n                    if (this.chartType === portal.dashboard.Constants.chartType.labels.TABLE) {\n                        clicked.col = data.col;\n                        clicked.colHeaders = data.colHeaders;\n                    }\n                } else if (this.chartType === portal.dashboard.Constants.chartType.labels.TIMELINE) {\n                    if(data.points && data.points.length > 0){\n                        clicked.start = data.points[0].x;\n                        clicked.end = data.points[data.points.length -1].x;\n                    }\n                    if (!Ext.isEmpty(this.categories)) {\n                        clicked[this.categories] = data.series.name;\n                    }\n                } else {\n                    // determine clicked data from Point object\n                    // Note: this assumed that grouped series have names containing all fields (separated by semi-colon)\n                    var pointValues = data.name ? [ data.name ] : data.series.name.split(';');\n                    if (data.category) { // column charts should have the category field\n                        pointValues.unshift(data.category);\n                    } else if (this.chartType !== portal.dashboard.Constants.chartType.labels.PIE && (Ext.isEmpty(this.groupBy) === false)) { // pie will alwalys have a category but no groupBy\n                        fields.shift(); // no category, remove from fields list\n                    }\n                    Ext.each(fields, function(fld, idx) {\n                        if (fld) {\n                            clicked[fld] = pointValues[idx].trim();\n                        }\n                    });\n                }\n                this.fireEvent('pointclick', this, this.query, clicked);\n            }\n        },\n\n        showNoResultsText: function() {\n            this.add(new Ext.BoxComponent({\n                html: Qx.DomUtils.center($L('156c8ffd-d952-497a-a59f-3a1587e02424', 'Your query has returned no results.'), 'api-no-result')\n            }));\n        },\n\n        getTrendPct: function(value, trendValue) {\n            if (value === 0) {\n                return trendValue > 0 ? -100 : 0;\n            } else {\n                var pct = ((trendValue - value) / trendValue) * 100 * -1;\n                return pct === Infinity ? 100 : pct;\n            }\n        },\n\n        showTrendPeriodMenu: function(e, box) {\n          